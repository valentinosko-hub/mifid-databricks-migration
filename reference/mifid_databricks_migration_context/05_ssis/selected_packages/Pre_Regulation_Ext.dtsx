      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{84BE269E-DF52-4F0E-8645-39996558119C}"
          SQLTask:SqlStatementSource="&#xA;&#xA;SELECT&#xA; CASE WHEN IsManual = 0 THEN DATEADD(DD,-1,CONVERT(DATETIME,CONVERT(VARCHAR,DATEADD(DD,0,GETDATE()),112) + ' 0:00'))&#xA;   ELSE StartDate_Manual END AS StartDate,&#xA;CASE  WHEN IsManual = 0 THEN CONVERT(DATETIME,CONVERT(VARCHAR,DATEADD(DD,0,GETDATE()),112) + ' 0:00')&#xA;     ELSE EndDate_Manual END AS EndDate,&#xA; EmailRecipients,&#xA; Active&#xA;FROM Reports_Control&#xA;WHERE ReportType =?"
          SQLTask:ResultType="ResultSetType_SingleRow" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
          <SQLTask:ResultBinding
            SQLTask:ResultName="0"
            SQLTask:DtsVariableName="User::StartDate" />
          <SQLTask:ResultBinding
            SQLTask:ResultName="1"
            SQLTask:DtsVariableName="User::EndDate" />
          <SQLTask:ResultBinding
            SQLTask:ResultName="2"
            SQLTask:DtsVariableName="User::EmailRecipients" />
          <SQLTask:ResultBinding
            SQLTask:ResultName="3"
            SQLTask:DtsVariableName="User::Active" />
          <SQLTask:ParameterBinding
            SQLTask:ParameterName="0"
            SQLTask:DtsVariableName="$Package::ReportType"
            SQLTask:ParameterDirection="Input"
            SQLTask:DataType="3"
            SQLTask:ParameterSize="-1" />
        </SQLTask:SqlTaskData>
      </DTS:ObjectData>
    </DTS:Executable>
