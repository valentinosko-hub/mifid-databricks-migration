                      name="OpenRowsetVariable"></property>
                    <property
                      dataType="System.String"
                      description="The SQL command to be executed."
                      name="SqlCommand"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">declare @StartDate datetime = ?
DECLARE @EndDate datetime = DATEADD(D,1,@StartDate)

SELECT  [PositionChangeID]
      ,[PositionID]
      ,[PreviousCloseOnEndOfWeek]
      ,[CloseOnEndOfWeek]
      ,[PreviousEndOfWeekFee]
      ,[EndOfWeekFee]
      ,[PreviousAmount]
      ,[AmountChanged]
      ,[PreviousLimitRate]
      ,[LimitRate]
      ,[PreviousStopRate]
      ,[StopRate]
      ,[Occurred]
      ,[ParentPositionID]
      ,[OrigParentPositionID]
      ,[LastOpPriceRate]
      ,[LastOpPriceRateID]
      ,[LastOpConversionRate]
      ,[LastOpConversionRateID]
      ,[MirrorID]
      ,[ClientVersion]
      ,[CID]
      ,[ChangeTypeID]
      ,[NewAmount]
      ,[PreviousLimitRateUnAdjusted]
      ,[PreviousStopRateUnAdjusted]
      ,[StopRateUnAdjusted]
      ,[LimitRateUnAdjusted]
      ,[MirrorRealizedEquity]
      ,[AccountRealizedEquity]
      ,[PrevTreeID]
      ,[TreeID]
      ,[SessionID]
      ,[IsTslEnabled]
      ,[RedeemStatus]
      ,[ClientRequestGuid]
      ,[PreviousIsSettled]
      ,cast([IsSettled] as int ) as IsSettled
      ,[PreviousAmountInUnits]
      ,[AmountInUnits]
      ,[PreviouseUnitsBaseValueCents]
      ,[UnitsBaseValueCents]
      ,[ClientViewRateID]
      ,[ClientViewRate]
  FROM History.PositionChangeLog   with (nolock)
WHERE Occurred &gt;= @StartDate  and Occurred &lt; @EndDate  AND ChangeTypeID in ( 0,13)</property>
