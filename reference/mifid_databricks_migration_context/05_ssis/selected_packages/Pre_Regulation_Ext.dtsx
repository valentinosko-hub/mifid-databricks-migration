            <SQLTask:SqlTaskData
              SQLTask:Connection="{84BE269E-DF52-4F0E-8645-39996558119C}"
              SQLTask:SqlStatementSource="DECLARE @RunDate date=CAST( ?  as datetime)&#xA;&#xA;DELETE FROM [dbo].[Reg_MigrationInOut_Population] WHERE [RunDate]=@RunDate&#xA;&#xA;DELETE FROM [dbo].[Reg_RegulationInOutDailyData]&#xA;WHERE [ReportDate]=@RunDate" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
