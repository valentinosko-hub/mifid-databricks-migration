  <DTS:Executables>
    <DTS:Executable
      DTS:refId="Package\Check LiquidityAccountID For Alerts"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{54793755-995E-411A-9475-6BE78E6D7ECE}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Check LiquidityAccountID For Alerts"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{84BE269E-DF52-4F0E-8645-39996558119C}"
          SQLTask:SqlStatementSource="SELECT a.LiquidityAccountID,a.AlertTypeID&#xA;&#x9;,typ.EmailTo&#xA;&#x9;,a.EmailSubject&#xA;&#x9;,EmailMessage=a.EmailMessage_Perfix+typ.EmailMessage&#xA;FROM (&#xA;--- Not Exist In Ext ---&#xA;&#x9;select scd.LiquidityAccountID&#xA;&#x9;&#x9;,1 as AlertTypeID&#xA;&#x9;&#x9;,EmailSubject='New LiquidityAccountID ('+cast(scd.LiquidityAccountID as varchar(20))+') '&#xA;&#x9;&#x9;,EmailMessage_Perfix='LiquidityAccountID '+cast(scd.LiquidityAccountID as varchar(20))+' '&#xA;&#x9;&#x9;,ex.LiquidityAccountName as LiquidityAccountName_Gsheet&#xA;&#x9;&#x9;,scd.LiquidityAccountName as LiquidityAccountName_SCD&#xA;&#x9;&#x9;,ex.RealOrCFD,ex.IsActive&#xA;&#x9;from Reg_LiquidtyAcount_SCD  scd&#xA;&#x9;&#x9;LEFT JOIN [dbo].[Reg_Ext_LiquidityAccountID] ex ON scd.[LiquidityAccountID]=ex.[LiquidityAccountID] &#xA;&#x9;where 1=1&#xA;&#x9;&#x9;and scd.IsLast=1&#xA;&#x9;&#x9;and ex.[LiquidityAccountID] is null -- currently not in ex&#xA;UNION ALL&#xA;--- LiquidityAccountName --&#xA;&#x9;select ex.LiquidityAccountID&#xA;&#x9;&#x9;,2 as AlertTypeID&#xA;&#x9;&#x9;,EmailSubject='LiquidityAccountName mismatch LiquidityAccountID ('+cast(ex.LiquidityAccountID as varchar(20))+') '&#xA;&#x9;&#x9;,EmailMessage_Perfix='This LiquidityAccountID has a value of &quot;'+scd.LiquidityAccountName+'&quot; '&#xA;&#x9;&#x9;,ex.LiquidityAccountName as LiquidityAccountName_Gsheet&#xA;&#x9;&#x9;,scd.LiquidityAccountName as LiquidityAccountName_SCD&#xA;&#x9;&#x9;,ex.RealOrCFD,ex.IsActive&#xA;&#x9;from [dbo].[Reg_Ext_LiquidityAccountID] ex&#xA;&#x9;&#x9;inner join [dbo].Reg_LiquidtyAcount_SCD scd on ex.LiquidityAccountID=scd.LiquidityAccountID&#xA;&#x9;where 1=1&#xA;&#x9;and scd.IsLast=1&#xA;&#x9;and isnull(ex.LiquidityAccountName,'')&lt;&gt;isnull(scd.LiquidityAccountName collate SQL_Latin1_General_CP1_CI_AS,'')&#xA;&#xA;UNION ALL&#xA;--- RealOrCFD -----&#xA;&#x9;select ex.LiquidityAccountID&#xA;&#x9;&#x9;,3 as AlertTypeID&#xA;&#x9;&#x9;,EmailSubject='RealOrCFD mismatch LiquidityAccountID ('+cast(ex.LiquidityAccountID as varchar(20))+') '&#xA;&#x9;&#x9;,EmailMessage_Perfix=''&#xA;&#x9;&#x9;,ex.LiquidityAccountName as LiquidityAccountName_Gsheet&#xA;&#x9;&#x9;,scd.LiquidityAccountName as LiquidityAccountName_SCD&#xA;&#x9;&#x9;,ex.RealOrCFD,ex.IsActive&#x9;&#xA;&#x9;from [dbo].[Reg_Ext_LiquidityAccountID] ex&#xA;&#x9;&#x9;inner join [dbo].Reg_LiquidtyAcount_SCD scd on ex.LiquidityAccountID=scd.LiquidityAccountID&#xA;&#x9;where 1=1&#xA;&#x9;and scd.IsLast=1&#xA;&#x9;and &#xA;&#x9;(&#xA;&#x9;&#x9;(&#xA;&#x9;&#x9;&#x9;UPPER(isnull(ex.RealOrCFD,''))&lt;&gt;'REAL'&#xA;&#x9;&#x9;&#x9;and (UPPER(ex.LiquidityAccountName) like 'REAL %' OR UPPER(ex.LiquidityAccountName) like '% REAL' OR UPPER(ex.LiquidityAccountName) like '% REAL %')&#xA;&#x9;&#x9;&#x9;and UPPER(ex.LiquidityAccountName) NOT like '%CFD%'&#xA;&#x9;&#x9;)&#xA;&#x9;&#x9;or&#xA;&#x9;&#x9;(&#xA;&#x9;&#x9;&#x9;UPPER(ex.RealOrCFD)='REAL' &#xA;&#x9;&#x9;&#x9;and &#xA;&#x9;&#x9;&#x9;(&#xA;&#x9;&#x9;&#x9;&#x9;(UPPER(ex.LiquidityAccountName) NOT like 'REAL %' and UPPER(ex.LiquidityAccountName) NOT like '% REAL' and UPPER(ex.LiquidityAccountName) NOT like '% REAL %')&#xA;&#x9;&#x9;&#x9;&#x9;or&#xA;&#x9;&#x9;&#x9;&#x9;UPPER(ex.LiquidityAccountName) like '%CFD%'&#xA;&#x9;&#x9;&#x9;)&#xA;&#x9;&#x9;)&#xA;&#x9;)&#xA;UNION ALL&#xA;--- IsActive ---&#xA;&#x9;select distinct ex.LiquidityAccountID&#xA;&#x9;&#x9;,4 as AlertTypeID&#xA;&#x9;&#x9;,EmailSubject='IsActive mismatch LiquidityAccountID ('+cast(ex.LiquidityAccountID as varchar(20))+') '&#xA;&#x9;&#x9;,EmailMessage_Perfix=''&#xA;&#x9;&#x9;,ex.LiquidityAccountName as LiquidityAccountName_Gsheet&#xA;&#x9;&#x9;,'N/A' as LiquidityAccountName_SCD&#xA;&#x9;&#x9;,ex.RealOrCFD,ex.IsActive&#xA;&#x9;from [dbo].[Reg_Ext_LiquidityAccountID] ex&#xA;&#x9;&#x9;inner join [dbo].Reg_Ext_HedgeExecutionLog hdg on ex.LiquidityAccountID=hdg.LiquidityAccountID&#xA;&#x9;where 1=1&#xA;&#x9;and (UPPER(ex.IsActive)&lt;&gt;'ACTIVE' or ex.IsActive is null)&#xA;) as a&#xA;&#x9;inner join [dbo].[Reg_LiquidityAccount_AlertsTypes] typ on a.AlertTypeID=typ.AlertTypeID&#xA;&#x9;LEFT JOIN [dbo].[Reg_LiquidityAccount_Alerts_History] ah on a.[LiquidityAccountID]=ah.[LiquidityAccountID]&#xA;&#x9;&#x9;and ah.AlertTypeID=a.AlertTypeID and ah.LastAlertSentDate&gt;getdate()-1&#xA;WHERE 1=1&#xA;&#x9;and isnull(ah.IsFixed,1)=1 /*if not in AlertsHistory from the last day, or in AlertsHistory from the last day and was fixed (and mismatch again)*/"
          SQLTask:ResultType="ResultSetType_Rowset" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
          <SQLTask:ResultBinding
            SQLTask:ResultName="0"
            SQLTask:DtsVariableName="User::LoopParams" />
        </SQLTask:SqlTaskData>
      </DTS:ObjectData>
    </DTS:Executable>
