              SQLTask:SqlStatementSource="declare @LiquidityAccountID int = ?&#xA;declare @AlertTypeID int = ?&#xA;declare @StartDate datetime = ?&#xA;&#xA;/* delete if exists: In Alerts_History and was fixed in Ext before (and currently not fixed in Ext) */&#xA;delete from [dbo].[Reg_LiquidityAccount_Alerts_History]&#xA;where LiquidityAccountID=@LiquidityAccountID&#xA;&#x9;and AlertTypeID=@AlertTypeID&#xA;&#xA;/* Insert - alert sent */&#xA;insert into [dbo].[Reg_LiquidityAccount_Alerts_History] (LiquidityAccountID,AlertTypeID,IsFixed,LastAlertSentDate)&#xA;values (@LiquidityAccountID,@AlertTypeID,0,@StartDate)&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
