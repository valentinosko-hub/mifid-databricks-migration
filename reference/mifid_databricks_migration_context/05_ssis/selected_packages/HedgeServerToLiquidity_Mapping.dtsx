    <DTS:Executable
      DTS:refId="Package\Update IsFixed"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{342FA8C5-C75C-4C1A-AF3F-8835A1EC5466}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Update IsFixed"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{84BE269E-DF52-4F0E-8645-39996558119C}"
          SQLTask:SqlStatementSource="/* Update IsFixed=1 if fixed for the relevant alert type */&#xA;&#xA;/* Not Exist In Ext */&#xA;Update ah&#xA;set ah.IsFixed=1&#xA;from [dbo].[Reg_LiquidityAccount_Alerts_History] ah&#xA;&#x9;inner join [dbo].[Reg_Ext_LiquidityAccountID] ex on ah.LiquidityAccountID=ex.LiquidityAccountID&#xA;where&#xA; ah.IsFixed=0&#xA; and ah.AlertTypeID=1 --not exist&#xA;&#xA;/* LiquidityAccountName */&#xA;Update ah&#xA;set ah.IsFixed=1&#xA;from [dbo].[Reg_LiquidityAccount_Alerts_History] ah&#xA;&#x9; inner join [dbo].[Reg_Ext_LiquidityAccountID] ex on ah.LiquidityAccountID=ex.LiquidityAccountID&#xA;&#x9; inner join [dbo].Reg_LiquidtyAcount_SCD scd on ex.LiquidityAccountID=scd.LiquidityAccountID&#xA;where&#xA;ah.IsFixed=0&#xA;and ah.AlertTypeID=2 --AccountName&#xA;and scd.IsLast=1&#xA;and ex.LiquidityAccountName=scd.LiquidityAccountName collate SQL_Latin1_General_CP1_CI_AS&#xA;&#xA;/* CFD-REAL */&#xA;Update ah&#xA;set ah.IsFixed=1&#xA;from [dbo].[Reg_LiquidityAccount_Alerts_History] ah&#xA;&#x9; inner join [dbo].[Reg_Ext_LiquidityAccountID] ex on ah.LiquidityAccountID=ex.LiquidityAccountID&#xA;where&#xA;ah.IsFixed=0&#xA;and ah.AlertTypeID=3 --CFD-REAL&#xA;and&#xA;(&#xA;&#x9;(&#xA;&#x9;&#x9;ex.RealOrCFD='REAL'&#xA;&#x9;&#x9;and (UPPER(ex.LiquidityAccountName) like 'REAL %' or UPPER(ex.LiquidityAccountName) like '% REAL' or UPPER(ex.LiquidityAccountName) like '% REAL %') &#xA;&#x9;&#x9;and UPPER(ex.LiquidityAccountName) NOT like '%CFD%'&#xA;&#x9;)&#xA;&#x9;or&#xA;&#x9;(&#xA;&#x9;&#x9;ex.RealOrCFD='CFD' &#xA;&#x9;&#x9;and &#xA;&#x9;&#x9;(&#xA;&#x9;&#x9;&#x9;(UPPER(ex.LiquidityAccountName) NOT like 'REAL %' and UPPER(ex.LiquidityAccountName) NOT like '% REAL' and UPPER(ex.LiquidityAccountName) NOT like '% REAL %')&#xA;&#x9;&#x9;&#x9;or &#xA;&#x9;&#x9;&#x9;UPPER(ex.LiquidityAccountName) like '%CFD%'&#xA;&#x9;&#x9;)&#xA;&#x9;)&#xA;)&#xA;&#xA;/* IsActive */&#xA;Update ah&#xA;set ah.IsFixed=1&#xA;from [dbo].[Reg_LiquidityAccount_Alerts_History] ah&#xA;&#x9;inner join [dbo].[Reg_Ext_LiquidityAccountID] ex on ah.LiquidityAccountID=ex.LiquidityAccountID&#xA;&#x9;inner join [dbo].Reg_Ext_HedgeExecutionLog hdg on ex.LiquidityAccountID=hdg.LiquidityAccountID&#xA;where&#xA;ah.IsFixed=0&#xA;and ah.AlertTypeID=4 --IsActive&#xA;and UPPER(ex.IsActive)='ACTIVE'&#xA;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
