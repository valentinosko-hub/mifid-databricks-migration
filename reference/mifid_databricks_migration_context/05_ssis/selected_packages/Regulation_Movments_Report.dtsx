            <DTS:Executable
              DTS:refId="Package\Enable only for Historic Run\RegInRegOut\RegInRegOut TranData"
              DTS:CreationName="Microsoft.ExecuteSQLTask"
              DTS:Description="RegInRegOut TranData"
              DTS:DTSID="{1184693E-CDDD-4858-A74B-FABA7853DE07}"
              DTS:ExecutableType="Microsoft.ExecuteSQLTask"
              DTS:LocaleID="-1"
              DTS:ObjectName="RegInRegOut TranData"
              DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
              DTS:ThreadHint="0">
              <DTS:Variables />
              <DTS:ObjectData>
                <SQLTask:SqlTaskData
                  SQLTask:Connection="{D3E007FD-70A8-488C-9B24-E29095BB28F3}"
                  SQLTask:SqlStatementSource="declare  @RunDate date=CAST( ?  as datetime)&#xA;--declare  @RunDate date=CAST( '2021-05-30'  as datetime)&#xA;&#xA;DROP TABLE IF EXISTS ##REG_MIGRATION ;&#xA;&#xA; with pop as (&#xA;&#x9;&#x9;&#x9;&#x9;SELECT DISTINCT CID&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;FROM    [etoro].[History].[BackOfficeCustomer]&#xA;&#x9;&#x9;&#x9;&#x9;where CAST(ValidFrom AS date) =CAST( @RunDate  AS date) &#xA;&#x9;&#x9;&#x9;&#x9;&#x9;AND  RegulationID IN (1,2,4,6,7,8,10) &#xA;&#x9;&#x9;)&#xA;&#x9;&#x9;SELECT @RunDate as RunDate, CID,Lei,RegulationID AS RegulationID,PrevValidTo AS Migration_Occurred ,PrevRegulationID&#xA;INTO ##REG_MIGRATION&#xA;FROM (&#xA;&#x9;SELECT  BOC.CID,  Lei, RegulationID ,ValidFrom,ValidTo,&#xA;&#x9;&#x9;LAG(ValidTo ,1 ) OVER (PARTITION BY BOC.CID ORDER BY ValidFrom) PrevValidTo, &#xA;&#x9;&#x9;LAG(RegulationID ,1 ) OVER (PARTITION BY BOC.CID ORDER BY ValidFrom) PrevRegulationID&#x9;&#xA;&#x9;FROM  [etoro].[History].[BackOfficeCustomer] BOC with (nolock) &#xA;&#x9;JOIN pop p ON BOC.CID = p.CID &#xA;) REG_MIG&#xA;WHERE CAST(ValidFrom AS date) =CAST(PrevValidTo AS date) AND RegulationID&lt;&gt;PrevRegulationID&#xA;AND CAST(ValidFrom AS date) =CAST( @RunDate  AS date) &#xA;&#x9;&#x9;--AND  RegulationID IN (1,2,4,6,7,8,10) /*Removed filter 20221003 DSR-1524*/&#xA;&#xA;&#xA;&#xA;DROP TABLE IF EXISTS #CID_REG_MOVE &#xA;&#xA;SELECT&#xA;&#x9;a.CID,&#x9;&#xA;&#x9;a.RegulationID,&#x9;&#xA;&#x9;a.PrevRegulationID,&#xA;&#x9;a.Migration_Occurred,&#xA;&#x9;a.Lei,&#xA;&#x9;b.FirstName, &#xA;&#x9;b.LastName&#xA;INTO #CID_REG_MOVE&#xA;FROM ##REG_MIGRATION  a&#xA;JOIN [etoro].[Customer].[Customer] b&#xA;&#x9;ON a.CID=b.CID&#xA;WHERE (RegulationID IN (1,2,4,10) AND PrevRegulationID IN (1,2,4,10))&#xA;&#xA;&#xA;CREATE Clustered INDEX #ix_ALL_Customer ON #CID_REG_MOVE (CID) ;&#xA;---------------------------------------------------------------------&#xA;-- select  * from #CID_REG_MOVE&#xA;---------------------------------------------------------------------&#xA;DROP TABLE IF EXISTS #ALL_POS_TRAN&#xA;&#xA;SELECT  * &#xA;INTO  #ALL_POS_TRAN&#xA;FROM &#xA;&#xA;(SELECT &#xA;&#x9;tp.PositionID,&#xA;&#x9;tp.CID,&#xA;&#x9;--tp.Occurred AS OpenOccurred,&#xA;&#x9;tp.Occurred AS OpenOccurred,&#xA;&#x9;CAST(NULL AS DATETIME) AS CloseOccurred,&#xA;&#x9;tp.InitForexRate,&#xA;&#x9;CAST(NULL AS DECIMAL(16,8)) AS EndForexRate,&#xA;&#x9;tp.AmountInUnitsDecimal,&#xA;&#x9;tp.InstrumentID,&#xA;&#x9;tp.IsBuy,&#xA;&#x9;tp.InitForexPriceRateID,&#xA;&#x9;null EndForexPriceRateID,&#xA;&#x9;c.RegulationID,&#xA;&#x9;c.PrevRegulationID,&#xA;&#x9;c.Migration_Occurred,&#xA;&#x9;c.Lei,&#xA;&#x9;c.FirstName, &#xA;&#x9;c.LastName,&#xA;&#x9;1 Type  -- from Trade=1&#xA;&#x9;FROM [etoro].[Trade].[Position] tp &#xA;&#x9;&#x9;JOIN #CID_REG_MOVE c on tp.CID=c.CID&#xA;&#x9;WHERE tp.Occurred&lt; DATEADD(D,1,@RunDate) &#xA;&#x9;&#xA;&#x9;UNION &#xA;&#x9;&#xA;&#x9;SELECT&#xA;&#x9;hp.PositionID,&#xA;&#x9;hp.CID,&#xA;&#x9;hp.OpenOccurred,&#xA;&#x9;hp.CloseOccurred,&#xA;&#x9;hp.InitForexRate,&#xA;&#x9;hp.EndForexRate,&#xA;&#x9;hp.AmountInUnitsDecimal,&#xA;&#x9;hp.InstrumentID,&#xA;&#x9;hp.IsBuy,&#xA;&#x9;hp.InitForexPriceRateID,&#xA;&#x9;hp.EndForexPriceRateID,&#xA;&#x9;c.RegulationID,&#xA;&#x9;c.PrevRegulationID,&#xA;&#x9;c.Migration_Occurred,&#xA;&#x9;c.Lei,&#xA;&#x9;c.FirstName, &#xA;&#x9;c.LastName,&#xA;&#x9;2 Type  -- from History=2&#xA;&#x9;FROM [etoro].[History].[Position] hp WITH (NOLOCK) &#xA;&#x9;&#x9;JOIN #CID_REG_MOVE c on hp.CID=c.CID&#xA;&#x9;WHERE OpenOccurred &lt; DATEADD(D,1,@RunDate)&#xA;&#x9;&#x9;AND CloseOccurred &gt;= @RunDate&#xA;) UN_POS&#xA;&#xA;&#xA;CREATE CLUSTERED INDEX #CI_ALL_POS_TRAN on #ALL_POS_TRAN(OpenOccurred,CloseOccurred,Type)&#xA;---------------------------------------------------------------------&#xA;---------------------------------------------------------------------&#xA;&#xA;DROP TABLE IF EXISTS #TRADE_OPEN&#xA;&#xA;SELECT &#xA;&#x9;TROP.PositionID&#xA;&#x9;,TROP.CID&#xA;&#x9;,TROP.InstrumentID&#xA;&#x9;,TROP.AmountInUnitsDecimal Quntity&#xA;&#x9;,TROP.IsBuy&#xA;&#x9;,TROP.InitForexPriceRateID&#xA;&#x9;,TROP.EndForexPriceRateID&#xA;&#x9;,TROP.InitForexRate ExecutionPrice&#xA;&#x9;,TROP.OpenOccurred  ExecutionTime&#xA;&#x9;,GETDATE() AS UpdateDate&#xA;&#x9;,TROP.RegulationID&#xA;&#x9;,TROP.PrevRegulationID&#xA;&#x9;,'O' OpenORClose&#xA;&#x9;,TROP.Migration_Occurred&#xA;&#x9;,TROP.Lei&#xA;&#x9;,TROP.FirstName &#xA;&#x9;,TROP.LastName&#xA;INTO #TRADE_OPEN&#xA;FROM #ALL_POS_TRAN TROP WITH (NOLOCK) &#xA;&#x9;WHERE TROP.OpenOccurred &gt;= Cast(@RunDate as date)&#xA;&#x9;&#x9;AND TROP.OpenOccurred&lt;Cast(dateadd(dd,1,@RunDate) as date)&#xA;&#x9;&#x9;AND TROP.Type=1&#xA;&#xA;DROP TABLE IF EXISTS #HISTORY_OPEN&#xA;&#xA;SELECT  &#xA;&#x9; HPOS.PositionID&#xA;&#x9;,HPOS.CID&#xA;&#x9;,HPOS.InstrumentID&#xA;&#x9;,HPOS.AmountInUnitsDecimal Quntity&#xA;&#x9;,HPOS.IsBuy&#xA;&#x9;,HPOS.InitForexPriceRateID&#xA;&#x9;,null EndForexPriceRateID&#xA;&#x9;,HPOS.InitForexRate  ExecutionPrice&#xA;&#x9;,HPOS.OpenOccurred  ExecutionTime&#xA;&#x9;,GETDATE() AS UpdateDate&#xA;&#x9;,HPOS.RegulationID&#xA;&#x9;,HPOS.PrevRegulationID&#xA;&#x9;,'O' OpenORClose&#xA;&#x9;,HPOS.Migration_Occurred&#xA;&#x9;,HPOS.Lei&#xA;&#x9;,HPOS.FirstName &#xA;&#x9;,HPOS.LastName&#xA;INTO #HISTORY_OPEN&#xA;FROM #ALL_POS_TRAN HPOS WITH (NOLOCK) &#xA;WHERE (HPOS.OpenOccurred &gt;= Cast(@RunDate as date)&#xA;&#x9;&#x9;AND HPOS.OpenOccurred&lt;Cast(dateadd(dd,1,@RunDate) as date))&#x9;&#xA;&#x9;&#x9;AND HPOS.Type=2&#xA;&#xA;DROP TABLE IF EXISTS #HISTORY_CLOSE&#xA;&#xA;SELECT &#xA;&#x9;HPCS.PositionID&#xA;&#x9;,HPCS.CID&#xA;&#x9;,HPCS.InstrumentID&#xA;&#x9;,HPCS.AmountInUnitsDecimal Quntity&#xA;&#x9;,HPCS.IsBuy&#xA;&#x9;,null InitForexPriceRateID&#xA;&#x9;,HPCS.EndForexPriceRateID&#xA;&#x9;,HPCS.EndForexRate ExecutionPrice&#xA;&#x9;,HPCS.CloseOccurred ExecutionTime&#xA;&#x9;,GETDATE() AS UpdateDate&#xA;&#x9;,HPCS.RegulationID&#xA;&#x9;,HPCS.PrevRegulationID&#xA;&#x9;,'C' OpenORClose&#xA;&#x9;,HPCS.Migration_Occurred&#xA;&#x9;,HPCS.Lei&#xA;&#x9;,HPCS.FirstName &#xA;&#x9;,HPCS.LastName&#xA;INTO #HISTORY_CLOSE&#xA;FROM #ALL_POS_TRAN HPCS WITH (NOLOCK) &#xA;WHERE (HPCS.CloseOccurred &gt;= Cast(@RunDate as date)&#xA;&#x9;&#x9;And HPCS.CloseOccurred&lt;Cast(dateadd(dd,1,@RunDate) as date))&#xA;&#x9;AND HPCS.Type=2&#x9;&#x9;&#x9;&#xA;-------------------------------------------------------------------&#x9;&#x9;&#x9;&#xA;---------------------------------------------------------------------&#xA;DROP TABLE IF EXISTS #OPEN_POS_DATA&#xA;&#xA;SELECT &#xA;&#x9;CID,&#xA;&#x9;RegulationID,&#xA;&#x9;PrevRegulationID,&#xA;&#x9;InstrumentID,&#xA;&#x9;Migration_Occurred,&#xA;&#x9;CAST(PositionID as varchar(15)) TransactionID,&#xA;&#x9;IsBuy,&#xA;&#x9;InitForexPriceRateID,&#xA;&#x9;NULL EndForexPriceRateID,&#xA;&#x9;InitForexRate ExecutionPrice,&#xA;&#x9;AmountInUnitsDecimal Quntity,&#xA;&#x9;OpenOccurred ExecutionTime,&#xA;&#x9;Lei,&#xA;&#x9;FirstName, &#xA;&#x9;LastName&#xA;INTO #OPEN_POS_DATA&#xA;FROM #ALL_POS_TRAN a&#xA;WHERE OpenOccurred &lt; Cast(dateadd(dd,1,@RunDate) as date)&#xA;&#x9;AND (CloseOccurred &gt; Cast(dateadd(dd,1,@RunDate) as date) or CloseOccurred is null)&#xA;&#xA;-------------------------------------------------------------------&#x9;&#x9;&#x9;&#xA;---------------------------------------------------------------------&#xA;-- Prepare #TRAN_DATA &#xA;--contain ---CID,InstrumentID,Migration_Occurred,TransactionID,IsBuy&#xA;&#xA;DROP TABLE IF EXISTS ##TRAN_DATA&#xA;&#xA;SELECT * &#xA;INTO  ##TRAN_DATA &#xA;&#x9;from &#xA;&#x9;&#x9;(SELECT CID,RegulationID,PrevRegulationID,InstrumentID,Migration_Occurred,cast(PositionID as Varchar(15))+OpenORClose TransactionID,&#xA;&#x9;&#x9;&#x9;&#x9;IsBuy,InitForexPriceRateID,EndForexPriceRateID,ExecutionPrice,Quntity,ExecutionTime,Lei,FirstName,LastName&#xA;&#x9;&#x9;&#x9;FROM #TRADE_OPEN&#xA;&#x9;&#x9;&#x9;UNION&#xA;&#x9;&#x9;&#x9;SELECT CID,RegulationID,PrevRegulationID,InstrumentID,Migration_Occurred,cast(PositionID as Varchar(15))+OpenORClose TransactionID,&#xA;&#x9;&#x9;&#x9;&#x9;IsBuy,InitForexPriceRateID,EndForexPriceRateID,ExecutionPrice,Quntity,ExecutionTime,Lei,FirstName,LastName&#xA;&#x9;&#x9;&#x9;FROM #HISTORY_OPEN&#xA;&#x9;&#x9;&#x9;UNION &#xA;&#x9;&#x9;&#x9;SELECT CID,RegulationID,PrevRegulationID,InstrumentID,Migration_Occurred,cast(PositionID as Varchar(15))+OpenORClose TransactionID,&#xA;&#x9;&#x9;&#x9;&#x9;IsBuy,InitForexPriceRateID,EndForexPriceRateID,ExecutionPrice,Quntity,ExecutionTime,Lei,FirstName,LastName&#xA;&#x9;&#x9;&#x9;FROM #HISTORY_CLOSE&#xA;&#x9;&#x9;&#x9;UNION &#xA;&#x9;&#x9;&#x9;SELECT &#xA;&#x9;&#x9;&#x9;&#x9;CID,RegulationID,PrevRegulationID,InstrumentID,Migration_Occurred,TransactionID,&#xA;&#x9;&#x9;&#x9;&#x9;IsBuy,InitForexPriceRateID,EndForexPriceRateID,ExecutionPrice,Quntity,ExecutionTime,Lei,FirstName,LastName&#xA;&#x9;&#x9;&#x9;FROM #OPEN_POS_DATA&#xA;&#x9;) U_TranExecutionPrice&#xA;--------------------------------------------------------------------&#xA;---------------------------------------------------------------------" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
                  <SQLTask:ParameterBinding
                    SQLTask:ParameterName="0"
                    SQLTask:DtsVariableName="User::StartDate"
                    SQLTask:ParameterDirection="Input"
                    SQLTask:DataType="7"
                    SQLTask:ParameterSize="-1" />
                </SQLTask:SqlTaskData>
              </DTS:ObjectData>
            </DTS:Executable>
