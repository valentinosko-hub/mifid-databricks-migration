          SQLTask:SqlStatementSource="SELECT&#xA; CASE WHEN IsManual = 0 THEN DATEADD(DD,-1,CONVERT(DATETIME,CONVERT(VARCHAR,DATEADD(DD,0,GETDATE()),112) + ' 0:00'))&#xA;   ELSE StartDate_Manual END  AS StartDate,&#xA;CASE  WHEN IsManual = 0 THEN CONVERT(DATETIME,CONVERT(VARCHAR,DATEADD(DD,0,GETDATE()),112) + ' 0:00')&#xA;     ELSE EndDate_Manual END  AS EndDate,&#xA; EmailRecipients,&#xA; Active&#xA;FROM Reports_Control&#xA;WHERE ReportType = ?"
