                </component>
                <component
                  refId="Package\Regulation Movments Report\Load Reg_Regulation_Movments_Positions\SRC RegSupportDB Ext_MigrationInOut_Population"
                  componentClassID="Microsoft.OLEDBSource"
                  contactInfo="OLE DB Source;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;7"
                  description="OLE DB Source"
                  name="SRC RegSupportDB Ext_MigrationInOut_Population"
                  usesDispositions="true"
                  validateExternalMetadata="False"
                  version="7">
                  <properties>
                    <property
                      dataType="System.Int32"
                      description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                      name="CommandTimeout">0</property>
                    <property
                      dataType="System.String"
                      description="Specifies the name of the database object used to open a rowset."
                      name="OpenRowset"></property>
                    <property
                      dataType="System.String"
                      description="Specifies the variable that contains the name of the database object used to open a rowset."
                      name="OpenRowsetVariable"></property>
                    <property
                      dataType="System.String"
                      description="The SQL command to be executed."
                      name="SqlCommand"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">declare @StartDate date = ?
declare @EndDate date = dateadd(day,1,@StartDate)

-- Open Positions  --
SELECT distinct
	@StartDate as [ReportDate]
	,mig.CID
	,mig.[RegulationID]
	,mig.[Migration_Occurred]
	,mig.[PrevRegulationID]
	,cast(tp.PositionID as bigint) as PositionID
	,tp.Occurred AS OpenOccurred
	,NULL as CloseOccurred
	,cast(tp.IsBuy as int) as IsBuy
	,tp.AmountInUnitsDecimal as Quantity
	,tp.InitForexRate as OpenPrice
	,NULL as ClosePrice
	,tp.InstrumentID as InstrumentID
	,cast(tp.IsSettled as int) as IsSettled --IsReal
	,IsOpenedAfterLastMigration = case when tp.Occurred &gt;= maxmig.Max_Migration_Occurred then 1 else 0 end
FROM [RegSupportDB].dbo.Ext_MigrationInOut_Population mig (nolock)
	inner join (
				select CID,MAX(Migration_Occurred) as Max_Migration_Occurred
				from [RegSupportDB].dbo.Ext_MigrationInOut_Population (nolock)
				group by CID
				) maxmig on mig.CID=maxmig.CID  -- last migration of the day
	inner join Trade.Position tp  (NOLOCK) on mig.CID=tp.CID 
		and (
				tp.Occurred &lt; mig.[Migration_Occurred]  -- was open before migration time (on prev regulation)
			or 
				(
				tp.Occurred &gt;= maxmig.Max_Migration_Occurred -- opened after last migration of the day (on "current" regulation)
				and maxmig.Max_Migration_Occurred = mig.[Migration_Occurred] --take only last migration
				) 
			)
where
	tp.Occurred &lt; @EndDate 

UNION ALL
-- closed positions --
SELECT distinct
	@StartDate as [ReportDate]
	,mig.CID
	,mig.[RegulationID]
	,mig.[Migration_Occurred]
	,mig.[PrevRegulationID]
	,cast(hp.PositionID as bigint) as PositionID
	,hp.OpenOccurred 
	,hp.CloseOccurred 
	,cast(hp.IsBuy as int) as IsBuy
	,hp.AmountInUnitsDecimal as Quantity
	,hp.InitForexRate as OpenPrice
	,hp.EndForexRate as ClosePrice
	,hp.InstrumentID as InstrumentID
	,cast(hp.IsSettled as int) as IsSettled --IsReal
	,IsOpenedAfterLastMigration = case when hp.OpenOccurred &gt;= maxmig.Max_Migration_Occurred then 1 else 0 end
FROM [RegSupportDB].dbo.Ext_MigrationInOut_Population mig (nolock)
	inner join (
					select CID,MAX(Migration_Occurred) as Max_Migration_Occurred
					from [RegSupportDB].dbo.Ext_MigrationInOut_Population (nolock)
					group by CID
				) maxmig on mig.CID=maxmig.CID -- last migration of the day
	inner join History.Position hp WITH (NOLOCK) on mig.CID=hp.CID 
		and (
				(
				hp.OpenOccurred &lt; mig.[Migration_Occurred] --  was open before migration time (on prev regulation)
				and hp.CloseOccurred&gt;=mig.[Migration_Occurred] -- moved regulation
				) 
			OR
				(
				hp.OpenOccurred &gt;= maxmig.Max_Migration_Occurred -- opened after last migration of the day (on "current" regulation)
				and maxmig.Max_Migration_Occurred = mig.[Migration_Occurred] --take only last migration
				)
			)
WHERE 
	hp.OpenOccurred &lt; @EndDate 

UNION ALL
-- Regulation movments without activity (if no results in the previous 2 queries, add only movment details) --
SELECT distinct
	@StartDate as [ReportDate]
	,mig.CID
	,mig.[RegulationID]
	,mig.[Migration_Occurred]
	,mig.[PrevRegulationID]
	,NULL as PositionID
	,NULL AS OpenOccurred
	,NULL as CloseOccurred
	,NULL as IsBuy
	,NULL as Quantity
	,NULL as OpenPrice
	,NULL as ClosePrice
	,NULL as InstrumentID
	,NULL as IsSettled --IsReal
	,IsOpenedAfterLastMigration = 0
FROM [RegSupportDB].dbo.Ext_MigrationInOut_Population mig (nolock)
	inner join (
				select CID,MAX(Migration_Occurred) as Max_Migration_Occurred
				from [RegSupportDB].dbo.Ext_MigrationInOut_Population (nolock)
				group by CID
				) maxmig on mig.CID=maxmig.CID  -- last migration of the day
	left join Trade.Position tp WITH (NOLOCK) on mig.CID=tp.CID AND tp.Occurred &lt; @EndDate
			and (
				tp.Occurred &lt; mig.[Migration_Occurred]  -- was open before migration time (on prev regulation)
			or 
				(
				tp.Occurred &gt;= maxmig.Max_Migration_Occurred -- opened after last migration of the day (on "current" regulation)
				and maxmig.Max_Migration_Occurred = mig.[Migration_Occurred] --take only last migration
				) 
			)
	left join History.Position hp WITH (NOLOCK) on mig.CID=hp.CID AND hp.OpenOccurred &lt; @EndDate
			and (
				(
				hp.OpenOccurred &lt; mig.[Migration_Occurred] --  was open before migration time (on prev regulation)
				and hp.CloseOccurred&gt;=mig.[Migration_Occurred] -- moved regulation
				) 
			OR
				(
				hp.OpenOccurred &gt;= maxmig.Max_Migration_Occurred -- opened after last migration of the day (on "current" regulation)
				and maxmig.Max_Migration_Occurred = mig.[Migration_Occurred] --take only last migration
				)
			)
WHERE 
	(tp.PositionID is null and hp.PositionID is null) -- only if no relevant activity</property>
