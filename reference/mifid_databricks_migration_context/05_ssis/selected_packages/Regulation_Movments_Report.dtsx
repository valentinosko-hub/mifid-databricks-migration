              DTS:ObjectName="DELETE ReportDate from 2 tables"
              DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
              DTS:ThreadHint="0">
              <DTS:Variables />
              <DTS:ObjectData>
                <SQLTask:SqlTaskData
                  SQLTask:Connection="{2208D0A6-4265-452C-8CCD-6239F30C6B2C}"
                  SQLTask:SqlStatementSource="DECLARE @RunDate date=CAST( ?  as datetime)&#xA;&#xA;DELETE FROM [dbo].[Reg_MigrationInOut_Population] WHERE [RunDate]=@RunDate&#xA;&#xA;DELETE FROM [dbo].[Reg_RegulationInOutDailyData]&#xA;WHERE [ReportDate]=@RunDate" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
