          DTS:DTSID="{F81568B1-02F6-42C4-894F-CCF255196BB4}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Update Reg_Regulation_Movments_Positions"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{2208D0A6-4265-452C-8CCD-6239F30C6B2C}"
              SQLTask:SqlStatementSource="declare @StartDate date = ?&#xA;&#xA;update reg&#xA;set&#xA; EOD_Price = CAST (&#xA;      CASE WHEN IsBuy=1 THEN (case when scd.SellCurrencyID=666 then cp.AskSpreaded/100.00 else cp.AskSpreaded end) &#xA;       ELSE (case when scd.SellCurrencyID=666 then cp.BidSpreaded/100.00 else cp.BidSpreaded end) &#xA;      END &#xA;     AS DECIMAL (16,6))&#xA; ,Symbol=scd.Symbol&#xA; ,IsMifid=scd.IsMifid&#xA; ,IsMifidByFCA=scd.IsMifidByFCA&#xA; ,UpdateDate = getdate()&#xA;from [dbo].[Reg_Regulation_Movments_Positions] reg&#xA; inner join [dbo].[Reg_Instruments_SCD] scd on reg.InstrumentID=scd.InstrumentID and scd.ValidFrom&lt;=reg.ReportDate and scd.ValidTo&gt;reg.ReportDate&#xA; inner join [dbo].[Reg_Ext_CurrencyPriceMaxDateWithSplit] cp on cp.InstrumentID=scd.InstrumentID and OccurredDate=reg.ReportDate&#xA;where &#xA;reg.ReportDate = @StartDate" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
              <SQLTask:ParameterBinding
                SQLTask:ParameterName="0"
                SQLTask:DtsVariableName="User::StartDate"
                SQLTask:ParameterDirection="Input"
                SQLTask:DataType="7"
                SQLTask:ParameterSize="-1" />
            </SQLTask:SqlTaskData>
          </DTS:ObjectData>
        </DTS:Executable>
