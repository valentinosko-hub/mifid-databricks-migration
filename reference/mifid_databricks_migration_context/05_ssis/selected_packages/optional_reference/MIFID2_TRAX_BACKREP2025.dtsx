                  <DTS:ObjectData>
                    <SQLTask:SqlTaskData
                      SQLTask:Connection="{7AF13DD3-409B-4C45-9BE9-2AEE6204F7EB}"
                      SQLTask:SqlStatementSource="DECLARE @RunDate date=CAST( ?  as datetime)&#xA;&#xA;DELETE FROM [dbo].[Reg_MigrationInOut_Population] WHERE [RunDate]=@RunDate&#xA;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
                      <SQLTask:ParameterBinding
