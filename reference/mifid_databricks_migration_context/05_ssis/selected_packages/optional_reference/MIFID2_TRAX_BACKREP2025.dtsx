          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{7AF13DD3-409B-4C45-9BE9-2AEE6204F7EB}"
              SQLTask:SqlStatementSource="DECLARE @MaxReportDate date = CONVERT(varchar,?,112)&#xA;&#xA;UPDATE dbo.MIFID2_TRAX_BKREP2025_Log&#xA;SET &#xA;    StartDateTime = getutcdate(),&#xA;    Stat = 'Started'&#xA;WHERE &#xA;    ReprotDate = @MaxReportDate&#xA;    AND StartDateTime IS NULL " xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
