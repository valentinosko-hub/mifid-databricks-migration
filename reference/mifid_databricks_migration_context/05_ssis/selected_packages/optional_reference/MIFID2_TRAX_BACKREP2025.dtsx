                          <properties>
                            <property
                              dataType="System.Int32"
                              description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                              name="CommandTimeout">0</property>
                            <property
                              dataType="System.String"
                              description="Specifies the name of the database object used to open a rowset."
                              name="OpenRowset"></property>
                            <property
                              dataType="System.String"
                              description="Specifies the variable that contains the name of the database object used to open a rowset."
                              name="OpenRowsetVariable"></property>
                            <property
                              dataType="System.String"
                              description="The SQL command to be executed."
                              name="SqlCommand"
                              UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">select b.GCID, c.ValueTypeID AS PIN_ID
	 , c.Name AS PIN_Type  
	 ,Value AS PIN
	,CountryId As UAPI_CountryID
from (SELECT GCID, [Value],TypeId, LastModified,CountryId, ROW_NUMBER() OVER (PARTITION BY GCID ORDER BY LastModified DESC) AS rn
		FROM [Customer].[ExtendedUserField] WITH (NOLOCK)
		WHERE FieldId=7
		) b
 join [Dictionary].[ExtendedUserValueType] c
on b.TypeId = c.ValueTypeID AND c.ValueTypeID &lt;&gt; 38 -- exclude CONCAT
where b.rn= 1
ORDER BY GCID</property>
