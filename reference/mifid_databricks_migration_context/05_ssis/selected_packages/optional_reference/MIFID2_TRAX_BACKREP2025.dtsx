                    <component
                      refId="Package\Foreach Loop Container\Sequence Container\MIFID2_ext_Customer MIFID2_ext_Position\HistoryPosition"
                      componentClassID="Microsoft.OLEDBSource"
                      contactInfo="OLE DB Source;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;7"
                      description="OLE DB Source"
                      name="HistoryPosition"
                      usesDispositions="true"
                      validateExternalMetadata="False"
                      version="7">
                      <properties>
                        <property
                          dataType="System.Int32"
                          description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                          name="CommandTimeout">0</property>
                        <property
                          dataType="System.String"
                          description="Specifies the name of the database object used to open a rowset."
                          name="OpenRowset"></property>
                        <property
                          dataType="System.String"
                          description="Specifies the variable that contains the name of the database object used to open a rowset."
                          name="OpenRowsetVariable"></property>
                        <property
                          dataType="System.String"
                          description="The SQL command to be executed."
                          name="SqlCommand"
                          UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">declare @StartDate date = ?
--declare @StartDate date = '2022-03-14'
DECLARE @EndDate date = DATEADD(D,1,@StartDate)

SELECT
	cast(hp.PositionID as bigint) AS PositionID,
	cast(hp.ParentPositionID as bigint) AS ParentPositionID,
	hp.CID,
	hp.OpenOccurred,
	hp.CloseOccurred,
	hp.InitForexRate,
	hp.EndForexRate,
	hp.AmountInUnitsDecimal,
	hp.InstrumentID,
	hp.IsBuy,
	hp.Leverage,
	convert(Decimal(16,8), NULL) AS LastOpConversionRate,
	hp.MirrorID,
	InitExecutionID,
	EndExecutionID,
	HedgeServerID,
	IsSettled,
	EndForexPriceRateID,
	InitForexPriceRateID, 
	LastOpPriceRate,
	cast(OriginalPositionID as bigint) AS OriginalPositionID,
	InitialUnits
FROM [RegSupportDB].dbo.TraxPositionForExternalUse hp WITH (NOLOCK)
	--JOIN Trade.GetInstrument TGI ON hp.InstrumentID = TGI.InstrumentID
	--JOIN Dictionary.Currency DC  
	--	ON DC.CurrencyID = TGI.BuyCurrencyID 
WHERE 
	 ( 
			(hp.CloseOccurred &gt;= @StartDate AND hp.CloseOccurred &lt; @EndDate)  -- Closed during
		OR	(hp.OpenOccurred &gt;= @StartDate AND hp.OpenOccurred &lt; @EndDate and hp.CloseOccurred &gt;= @EndDate) -- Open during and closed after
		)
	AND hp.OpenOccurred &gt;= '2015-04-26' -- 22-4-2015
	--AND (TGI.InstrumentTypeID not in (1,5,10) OR (TGI.InstrumentTypeID = 5 AND DC.EEAStockExchange =1))  -- Instruments filter in proc 20190922
	--AND hp.InstrumentID &lt; 100000
ORDER BY hp.CID</property>
