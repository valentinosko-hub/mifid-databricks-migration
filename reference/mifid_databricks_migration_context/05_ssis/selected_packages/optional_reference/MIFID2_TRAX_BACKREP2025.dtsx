        <DTS:Executable
          DTS:refId="Package\Foreach Loop Container\update backrep log"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{4A40ED0F-989B-4A38-9377-0F8DFC37B8A0}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="update backrep log"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{7AF13DD3-409B-4C45-9BE9-2AEE6204F7EB}"
              SQLTask:SqlStatementSource="-- Declare a variable to store the max ReportDate&#xA;DECLARE @MaxReportDate DATE&#xA;&#xA;set @MaxReportDate = isnull((SELECT MAX([ReportDate]) FROM [dbo].[MIFID2_NPD_TRAX_DSR_8497]),'2025-01-08')&#xA;print @MaxReportDate&#xA;&#xA;-- Update the matching log record where ReprotDate = @MaxReportDate&#xA;UPDATE dbo.MIFID2_TRAX_BKREP2025_Log&#xA;SET &#xA;    EndDateTime = GETUTCDATE(),&#xA;    Stat = 'Processed'&#xA;WHERE &#xA;    ReprotDate = @MaxReportDate&#xA;    AND EndDateTime IS NULL &#xA; AND Stat='Started'&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
          DTS:refId="Package\Foreach Loop Container\validate if to  run or stop"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{FEF786B8-6537-4372-B10E-2075CC3F36BC}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="validate if to  run or stop"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{7AF13DD3-409B-4C45-9BE9-2AEE6204F7EB}"
              SQLTask:SqlStatementSource="--- Time Check Loop&#xA;DECLARE @currentHour INT&#xA;DECLARE @StopHour INT = 21&#xA;DECLARE @StartHour INT = 7&#xA;--PRINT CONVERT(VARCHAR(25),GETUTCDATE(),12)&#xA;&#xA;WHILE 1 = 1&#xA;BEGIN&#xA;    SET @currentHour = DATEPART(HOUR, GETUTCDATE())&#xA;&#xA;    IF @currentHour &gt;= @StartHour AND @currentHour &lt; @StopHour&#xA;    BEGIN&#xA;        PRINT 'Within allowed run window. Proceeding...next date -MIFID2_TRAX_BKREP2025'&#xA;        BREAK -- Exit the loop, time is valid&#xA;    END&#xA;    ELSE&#xA;    BEGIN&#xA;        DECLARE @currentHour_str VARCHAR(25) = CAST(@currentHour AS VARCHAR)&#xA;        DECLARE @bodyText VARCHAR(4000) = 'Current UTC hour is ' + @currentHour_str +&#xA;            '. Execution for MIFID2_TRAX_BKREP2025 is paused; outside of allowed hours (06:00 - 21:00 UTC). Retrying in 1 hour.'&#xA;&#xA;        EXEC msdb.dbo.sp_send_dbmail &#xA;            @recipients = 'davidsi@etoro.com;', &#xA;            @subject = 'MIFID2_TRAX_BKREP2025 Waiting: Outside Allowed Execution Window',&#xA;            @body = @bodyText&#xA;&#xA;        PRINT 'MIFID2_TRAX_BKREP2025 Outside allowed window. Waiting for 1 hour before rechecking...'&#xA;&#x9;&#x9;WAITFOR DELAY '01:00:00'&#xA;    END&#xA;END" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
      </DTS:Executables>
