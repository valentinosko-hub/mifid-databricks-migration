    <DTS:Executable
      DTS:refId="Package\Sequence Container 2"
      DTS:CreationName="STOCK:SEQUENCE"
      DTS:Description="Sequence Container"
      DTS:Disabled="True"
      DTS:DTSID="{B55B551C-62AD-4825-B707-45811FC4C3A1}"
      DTS:ExecutableType="STOCK:SEQUENCE"
      DTS:LocaleID="-1"
      DTS:ObjectName="Sequence Container 2">
      <DTS:Variables />
      <DTS:Executables>
        <DTS:Executable
          DTS:refId="Package\Sequence Container 2\Execute Prep BestEX Client Data"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{8903A6FF-EB87-4D58-AF73-9D97D8E7D7E4}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Execute Prep BestEX Client Data"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2017 RC1; © 2017 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="3">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{EBFA952B-7FB1-4C30-99D8-74682F8D5539}"
              SQLTask:SqlStatementSource="&#xA;&#xA;&#xA;/*----------- BEST_EX_RES_CLIENT ----------*/&#xA;&#xA;declare  @RunDate date=CAST(? as datetime)&#xA;/*---------------------------------------------------------------------*/&#xA;DECLARE @EndDate date = DATEADD(D,1,@RunDate)&#xA;&#xA;drop table if exists #ALL_Customer ;&#xA;&#xA;WITH customer (CID,RegulationID,LabelID,PayerLevelID,CountryID)&#xA;AS  (&#xA;SELECT a.CID,b.RegulationID,a.LabelID,a.PlayerLevelID, a.CountryID&#xA;FROM (&#xA;SELECT CID, LabelID, PlayerStatusID,PlayerLevelID, CountryID, FirstName, LastName&#xA;&#xA;FROM History.Customer  &#xA;WHERE ValidFrom &lt; DATEADD(D,1,@RunDate) AND ValidTo &gt; DATEADD(D,1,@RunDate)&#xA;AND LabelID not in (26,30)&#xA;AND not (PlayerLevelID=4 or CountryID=250)&#xA;&#xA;&#xA;) a&#xA;JOIN (&#xA;SELECT CID, RegulationID&#xA;FROM History.BackOfficeCustomer with (nolock)&#xA;WHERE ValidFrom &lt; DATEADD(D,1,@RunDate) AND ValidTo &gt; DATEADD(D,1,@RunDate)&#xA;AND RegulationID in (1,2,4,6,7,8,10)   ----   fix arielak 20210414  remove RegulationID = 9 &#xA;&#xA;) b&#xA;ON a.CID = b.CID&#xA;JOIN Customer.Customer c  with (nolock)&#xA;ON a.CID = c.CID&#xA;)&#xA;SELECT a.[CID],a.[RegulationID]&#xA;into #ALL_Customer&#xA;FROM customer a&#xA;&#xA;CREATE Clustered INDEX #ix_ALL_Customer ON #ALL_Customer (CID) ;&#xA;/*---------------------------------------------------------------------*/&#xA;DROP TABLE  IF EXISTS #ChangeLog&#xA;select  T.* &#xA;into #ChangeLog&#xA;from&#xA;(&#xA;SELECT PositionID,IsSettled&#xA;--, ROW_NUMBER() OVER (PARTITION BY PositionID ORDER BY Occurred DESC) AS RN&#xA;FROM History.PositionChangeLog  a with (nolock)&#xA;WHERE a.Occurred &gt;= @RunDate  and Occurred &lt; DATEADD(D,1,@RunDate)&#xA;AND a.ChangeTypeID = 0 &#xA;&#xA;) T&#xA;--WHERE RN = 1 &#xA;CREATE Clustered INDEX #ix_ChangeLog ON #ChangeLog (PositionID) ;&#xA;&#xA;/*---------------------------------------------------------------------*/&#xA;DROP TABLE IF EXISTS   #splits&#xA;select distinct a.InstrumentID, MinDate, MaxDate, AmountRatio, IsCompletedOpenPositions, AmountRatioUnAdjusted&#xA;into #splits&#xA;from [History].[SplitRatio]  a WITH (NOLOCK) &#xA;where IsCompletedOpenPositions = 1 &#xA;&#xA;/*---------------------------------------------------------------------*/&#xA;&#xA;drop  table if  exists #CurrencyPrice_Active&#xA;select a.PriceRateID,&#xA;  a.Ask, a.Bid, a.AskSpreaded, a.BidSpreaded, a.USDConversionRate,a.Occurred, a.InstrumentID&#xA;  into   #CurrencyPrice_Active&#xA;from PriceLog.History.CurrencyPrice_Active a  with (nolock)&#xA; where Occurred&gt;=DATEADD(HOUR, -1, cast(@RunDate as datetime)) AND Occurred &lt;= dateadd(day,datediff(day,-1,@RunDate),0)&#xA;&#xA; CREATE Clustered INDEX #IX_CL_CurrencyPrice_Active ON #CurrencyPrice_Active (PriceRateID) ;&#xA;/*---------------------------------------------------------------------*/&#xA;&#xA;drop table if exists #TRADE_OPEN&#xA;&#xA;SELECT &#xA;  TROP.PositionID&#xA;  , null OriginalPositionID&#xA;   ,TROP.CID&#xA;   ,TROP.InstrumentID&#xA;   ,TROP.Occurred as OpenOccurred&#xA;   ,NULL as CloseOccurred&#xA;   ,TROP.AmountInUnitsDecimal&#xA;   ,TROP.InitForexRate&#xA;   ,CAST(NULL AS DECIMAL(16,8)) AS EndForexRate&#xA;   --,TROP.NetProfit&#xA;   ,TROP.Amount&#xA;   ,TROP.IsBuy&#xA;   ,coalesce(CL.IsSettled,TROP.IsSettled) IsSettled&#xA;   --,TROP.[LastOpPriceRate]&#xA;   ,case when TROP.IsBuy=1 then CPA.Ask else CPA.Bid end AS ExecutionPrice&#xA;   ,GETDATE() AS UpdateDate&#xA;   ,TROP.HedgeServerID&#xA;   ,null EndExecutionID&#xA;   ,TROP.InitExecutionID&#xA;   ,TROP.RequestOccurred as RequestOpenOccurred&#xA;   ,NULL as RequestCloseOccurred&#xA;   ,AC.RegulationID&#xA;   ,CPA.USDConversionRate&#xA;   ,COALESCE(CPA.Occurred,TROP.Occurred)  as ExecutionTime&#xA;   ,Case when TROP.TreeID= TROP.PositionID Then 1 else 0 end as isManual&#xA;   ,TROP.IsDiscounted    &#xA;&#xA;   ,OrderID&#xA;   ,null ActionType &#xA;   ,null StopRate  &#xA;   ,null LimitRate&#xA;   into #TRADE_OPEN&#xA; FROM Trade.Position TROP WITH (NOLOCK) &#xA;   LEFT JOIN #ChangeLog CL WITH (NOLOCK)  ON TROP.PositionID=CL.PositionID&#xA;   LEFT JOIN  #CurrencyPrice_Active CPA ON TROP.InitForexPriceRateID=CPA.PriceRateID and TROP.InstrumentID= CPA.InstrumentID&#xA;   JOIN #ALL_Customer AC  WITH (NOLOCK)  ON TROP.CID=AC.CID&#xA;  WHERE TROP.Occurred &gt;= Cast(@RunDate as date)&#xA;  And TROP.Occurred&lt;Cast(dateadd(dd,1,@RunDate) as date)&#xA;&#xA;/*---------------------------------------------------------------------*/&#xA;drop table if exists #HISTORY_OPEN&#xA;&#xA;SELECT  &#xA;  HPOS.PositionID&#xA;  ,HPOS.OriginalPositionID&#xA;   ,HPOS.CID&#xA;   ,HPOS.InstrumentID&#xA;   ,HPOS.OpenOccurred&#xA;   ,NULL as CloseOccurred&#xA;   ,HPOS.AmountInUnitsDecimal&#xA;   ,HPOS.InitForexRate&#xA;   ,HPOS.EndForexRate&#xA;   --,HPOS.NetProfit&#xA;   ,HPOS.Amount&#xA;   ,HPOS.IsBuy&#xA;   ,coalesce(CL2.IsSettled,CL.IsSettled,HPOS.IsSettled) IsSettled&#xA;   --,HPOS.[LastOpPriceRate]&#xA;   ,case when HPOS.IsBuy=1 then CPA.Ask else CPA.Bid end AS ExecutionPrice&#xA;   ,GETDATE() AS UpdateDate&#xA;    ,HPOS.HedgeServerID&#xA;   ,HPOS.InitExecutionID&#xA;   ,null EndExecutionID&#xA;   ,HPOS.RequestOpenOccurred&#xA;   ,HPOS.RequestCloseOccurred&#xA;   ,AC.RegulationID&#xA;   ,CPA.USDConversionRate&#xA;   ,COALESCE(CPA.Occurred,HPOS.OpenOccurred)  as ExecutionTime&#xA;   ,Case when HPOS.TreeID= HPOS.PositionID Then 1 else 0 end as isManual&#xA;   ,HPOS.IsDiscounted   &#xA;   &#xA;   ,OrderID&#xA;   ,null ActionType&#xA;   ,null StopRate  &#xA;   ,null LimitRate&#xA;    into #HISTORY_OPEN&#xA; FROM History.Position HPOS WITH (NOLOCK) &#xA;   LEFT JOIN #ChangeLog CL WITH (NOLOCK)  ON HPOS.PositionID=CL.PositionID&#xA;   LEFT JOIN #ChangeLog CL2 WITH (NOLOCK)  ON HPOS.OriginalPositionID=CL2.PositionID&#xA;   LEFT JOIN  #CurrencyPrice_Active CPA ON HPOS.InitForexPriceRateID=CPA.PriceRateID and HPOS.InstrumentID = CPA.InstrumentID&#xA;   JOIN #ALL_Customer AC  WITH (NOLOCK)  ON HPOS.CID=AC.CID&#xA; WHERE (HPOS.OpenOccurred &gt;= Cast(@RunDate as date)&#xA;   And HPOS.OpenOccurred&lt;Cast(dateadd(dd,1,@RunDate) as date))  &#xA;/*---------------------------------------------------------------------*/&#xA;drop table if exists #HISTORY_CLOSE&#xA;&#xA;SELECT &#xA;  HPCS.PositionID&#xA;  ,HPCS.OriginalPositionID&#xA;   ,HPCS.CID&#xA;   ,HPCS.InstrumentID&#xA;   ,NULL as OpenOccurred&#xA;   ,HPCS.CloseOccurred&#xA;   ,AmountInUnitsDecimal&#xA;   ,HPCS.InitForexRate&#xA;   ,HPCS.EndForexRate&#xA;   --,HPCS.NetProfit&#xA;   ,HPCS.Amount&#xA;   ,HPCS.IsBuy&#xA;   ,HPCS.IsSettled&#xA;   --,HPCS.LastOpPriceRate&#xA;   ,case when HPCS.IsBuy=1 then CPA.Bid else CPA.Ask end AS ExecutionPrice -- reversed logic from Open &#xA;    ,HPCS.HedgeServerID&#xA;   ,HPCS.InitExecutionID&#xA;   ,HPCS.EndExecutionID&#xA;   ,GETDATE() AS UpdateDate&#xA;   ,HPCS.RequestOpenOccurred&#xA;   ,HPCS.RequestCloseOccurred&#xA;   ,AC.RegulationID&#xA;   ,CPA.USDConversionRate&#xA;   ,COALESCE(CPA.Occurred,HPCS.CloseOccurred)  as ExecutionTime&#xA;   ,Case when HPCS.ActionType in (0,17) then 1 else 0 end as isManual&#xA;   ,HPCS.IsDiscounted    &#xA;&#xA;   ,null OrderID&#xA;   ,ActionType&#xA;   ,StopRate  &#xA;   ,LimitRate &#xA;    into #HISTORY_CLOSE&#xA; FROM History.Position HPCS WITH (NOLOCK) &#xA;   JOIN #ALL_Customer AC  WITH (NOLOCK)  ON HPCS.CID=AC.CID&#xA;   LEFT JOIN  #CurrencyPrice_Active CPA ON HPCS.EndForexPriceRateID=CPA.PriceRateID and HPCS.InstrumentID= CPA.InstrumentID&#xA; WHERE (HPCS.CloseOccurred &gt;= Cast(@RunDate as date)&#xA;   And HPCS.CloseOccurred&lt;Cast(dateadd(dd,1,@RunDate) as date)) &#xA;/*---------------------------------------------------------------------*/&#xA;-- PERP TRADES WHERE HEDGE EXECUTION IS HBC (HEDGE BEFORE CONFIRM)&#xA;/*---------------------------------------------------------------------*/&#xA;drop table if exists #OPEN_TRADES_HBC&#xA;select  PT.*,HBC.LPExecutionRate as ExecutionPrice_2&#xA;into #OPEN_TRADES_HBC&#xA;from &#xA;(SELECT CID,PositionID,'O' OpenORClose ,InstrumentID,IsBuy,AmountInUnitsDecimal ,CAST(OpenOccurred AS DATE) as Trade_date,ExecutionPrice,ExecutionTime&#xA;  ,OpenOccurred,CloseOccurred,HedgeServerID,OriginalPositionID,InitExecutionID,EndExecutionID,RequestOpenOccurred,RequestCloseOccurred,InitExecutionID ExecutionID&#xA;  ,RegulationID,IsSettled,USDConversionRate,isManual,InitForexRate,EndForexRate,OrderID,ActionType,StopRate,LimitRate,IsDiscounted&#xA; from #TRADE_OPEN   with (nolock)&#xA; UNION all&#xA; select CID,PositionID,'O' OpenORClose,InstrumentID,IsBuy,AmountInUnitsDecimal ,CAST(OpenOccurred AS DATE) as Trade_date,ExecutionPrice,ExecutionTime&#xA;  ,OpenOccurred,CloseOccurred,HedgeServerID,OriginalPositionID,InitExecutionID,EndExecutionID,RequestOpenOccurred,RequestCloseOccurred,InitExecutionID ExecutionID&#xA;  ,RegulationID,IsSettled,USDConversionRate,isManual,InitForexRate,EndForexRate,OrderID,ActionType,StopRate,LimitRate,IsDiscounted&#xA; from #HISTORY_OPEN   with (nolock)&#xA; ) PT&#xA;join Hedge.HBCExecutionLog HBC WITH (NOLOCK)  ON PT.InitExecutionID=HBC.ExecutionID&#xA;AND HBC.IsSuccess = 1  &#xA;&#xA;CREATE NONCLUSTERED INDEX #ix_OPEN_TRADES_HBC ON #OPEN_TRADES_HBC (ExecutionID) &#xA;&#xA;/*---------------------------------------------------------------------*/ &#xA;drop table if exists #CLOSE_TRADES_HBC&#xA;select  PT.*,HBC.LPExecutionRate as ExecutionPrice_2&#xA;into #CLOSE_TRADES_HBC&#xA;from (&#xA; select CID,PositionID,'C' OpenORClose,InstrumentID,IsBuy,AmountInUnitsDecimal ,CAST(CloseOccurred AS DATE) as Trade_date,ExecutionPrice,ExecutionTime&#xA;  ,OpenOccurred,CloseOccurred,HedgeServerID,OriginalPositionID,InitExecutionID,EndExecutionID,RequestOpenOccurred,RequestCloseOccurred,EndExecutionID ExecutionID&#xA;  ,RegulationID,IsSettled,USDConversionRate,isManual,InitForexRate,EndForexRate,OrderID,ActionType,StopRate,LimitRate,IsDiscounted&#xA; from #HISTORY_CLOSE  with (nolock)&#xA; )  PT&#xA;join Hedge.HBCExecutionLog HBC WITH (NOLOCK)  ON PT.EndExecutionID=HBC.ExecutionID&#xA;AND HBC.IsSuccess = 1 &#xA;&#xA;CREATE NONCLUSTERED INDEX #ix_CLOSE_TRADES_HBC ON #CLOSE_TRADES_HBC (ExecutionID) &#xA;/*---------------------------------------------------------------------*/&#xA; DECLARE @MinRequestID INT    &#xA; DECLARE @MaxRequestID INT    &#xA; SELECT @MinRequestID = MIN(ExecutionID),    &#xA;        @MaxRequestID = MAX(ExecutionID)    &#xA; from #CLOSE_TRADES_HBC  WHERE ExecutionID &gt; 0    &#xA;     &#xA; DECLARE @BMinRequestID INT    &#xA; DECLARE @BMaxRequestID INT    &#xA; SELECT @BMinRequestID = MIN(ExecutionID),    &#xA;        @BMaxRequestID = MAX(ExecutionID)    &#xA; FROM #OPEN_TRADES_HBC  WHERE ExecutionID &gt; 0    &#xA;     &#xA; DECLARE @MinMinRequestID INT    &#xA; DECLARE @MaxMaxRequestID INT    &#xA;     &#xA; SELECT @MinMinRequestID = CASE WHEN @MinRequestID &lt; @BMinRequestID THEN @MinRequestID ELSE @BMinRequestID END    &#xA; SELECT @MaxMaxRequestID = CASE WHEN @MaxRequestID &gt; @BMaxRequestID THEN @MaxRequestID ELSE @BMaxRequestID END    &#xA;     &#xA;    &#xA;DROP TABLE IF EXISTS #rlel    &#xA;    &#xA; SELECT RequestID, MarketTriggerRateTime,TriggerPriceRateID,BidSpreaded,AskSpreaded      &#xA; INTO #rlel    &#xA; FROM eToroLogs_Real.eToroLogs_Real.Hedge.RequestLimitExecutionLog a with (nolock) &#xA; JOIN   [PriceLog].[History].[CurrencyPrice] b  with (nolock) ON a.TriggerPriceRateID=b.PriceRateID    &#xA; WHERE a.RequestID &gt;= @MinMinRequestID    &#xA; AND a.RequestID &lt;= @MaxMaxRequestID   &#xA; AND b.Occurred&gt;=Cast(@RunDate as date)&#xA; and b.Occurred &lt;Cast(dateadd(dd,1,@RunDate) as date) &#xA;&#xA; /*---------------------------------------------------------------------*/ &#xA;          &#xA;DROP TABLE IF EXISTS #rel   &#xA; &#xA; SELECT RequestID, RequestTime,ClientViewRate      &#xA; INTO #rel    &#xA; FROM eToroLogs_Real.eToroLogs_Real.Hedge.RequestExecutionLog with (nolock)    &#xA; WHERE RequestID &gt;= @MinMinRequestID    &#xA; AND RequestID &lt;= @MaxMaxRequestID    &#xA;     &#xA;CREATE NONCLUSTERED INDEX #rel ON #rel ([RequestID]) INCLUDE ([RequestTime])&#xA;/*---------------------------------------------------------------------*/   &#xA;DROP TABLE IF EXISTS #ALL_TRADES_HBC &#xA;select  *,'HBC' AS HedgingType &#xA;into #ALL_TRADES_HBC&#xA;FROM &#xA;(&#xA;Select  A.* &#xA;     ,rlel.MarketTriggerRateTime    &#xA;     ,rel.RequestTime&#xA;     ,CASE WHEN rlel.TriggerPriceRateID is not null THEN rlel.MarketTriggerRateTime  &#xA;       WHEN A.RequestCloseOccurred &lt; rel.RequestTime  THEN A.RequestCloseOccurred       &#xA;       ELSE rel.RequestTime END OrderTime&#xA;     ,rlel.TriggerPriceRateID&#xA;     ,rlel.BidSpreaded&#xA;     ,rlel.AskSpreaded&#xA;     ,rel.ClientViewRate &#xA;     ,null HedgeExecutionModeID&#xA;&#xA;  FROM #CLOSE_TRADES_HBC A     &#xA;   JOIN #rel rel WITH (NOLOCK)    &#xA;    ON rel.RequestID = A.ExecutionID    &#xA;   LEFT JOIN #rlel rlel WITH (NOLOCK)    &#xA;    ON rlel.RequestID = A.ExecutionID   &#xA;UNION ALL&#xA;Select  B.*  &#xA;     ,null MarketTriggerRateTime    &#xA;     ,rel.RequestTime  &#xA;     ,CASE WHEN B.RequestOpenOccurred &lt; rel.RequestTime  THEN  B.RequestOpenOccurred ELSE rel.RequestTime  END  OrderTime &#xA;     ,null TriggerPriceRateID&#xA;     ,null BidSpreaded&#xA;     ,null AskSpreaded &#xA;     ,rel.ClientViewRate&#xA;     ,null HedgeExecutionModeID&#xA; FROM #OPEN_TRADES_HBC B     &#xA; JOIN #rel rel WITH (NOLOCK)    &#xA; ON rel.RequestID = B.ExecutionID&#xA;) UN_T  &#xA;&#xA;CREATE Clustered INDEX #ix_ALL_TRADES_HBC ON #ALL_TRADES_HBC (PositionID) &#xA;&#xA;/*---------------------------------------------------------------------*/  &#xA;-- PERP TRADES WHERE HEDGE EXECUTION IS CBH (CONFIRM BEFORE HEDGE)&#xA;/*---------------------------------------------------------------------*/&#xA;drop table if exists #OPEN_TRADES_CBH&#xA;select  PT.* ,null  as ExecutionPrice_2  &#xA;into #OPEN_TRADES_CBH&#xA;from &#xA;(SELECT CID,PositionID,'O' OpenORClose ,InstrumentID,IsBuy,AmountInUnitsDecimal ,CAST(OpenOccurred AS DATE) as Trade_date,ExecutionPrice,ExecutionTime&#xA;  ,OpenOccurred,CloseOccurred,HedgeServerID,OriginalPositionID,InitExecutionID,EndExecutionID,RequestOpenOccurred,RequestCloseOccurred,InitExecutionID ExecutionID&#xA;  ,RegulationID,IsSettled,USDConversionRate,isManual,InitForexRate,EndForexRate,OrderID,ActionType,StopRate,LimitRate,IsDiscounted&#xA; from #TRADE_OPEN   &#xA; UNION All&#xA; select CID,PositionID,'O' OpenORClose,InstrumentID,IsBuy,AmountInUnitsDecimal ,CAST(OpenOccurred AS DATE) as Trade_date,ExecutionPrice,ExecutionTime&#xA;  ,OpenOccurred,CloseOccurred,HedgeServerID,OriginalPositionID,InitExecutionID,EndExecutionID,RequestOpenOccurred,RequestCloseOccurred,InitExecutionID ExecutionID&#xA;  ,RegulationID,IsSettled,USDConversionRate,isManual,InitForexRate,EndForexRate,OrderID,ActionType,StopRate,LimitRate,IsDiscounted&#xA; from #HISTORY_OPEN &#xA; ) PT&#xA;LEFT join #OPEN_TRADES_HBC FLT ON FLT.PositionID=PT.PositionID&#xA;where FLT.PositionID is null&#xA;&#xA;/*---------------------------------------------------------------------*/ &#xA;&#xA;CREATE NONCLUSTERED INDEX #ix_OPEN_TRADES_CBH ON #OPEN_TRADES_CBH (ExecutionID) &#xA;&#xA;drop table if exists #CLOSE_TRADES_CBH&#xA;select  PT.*,null  as ExecutionPrice_2 &#xA;into #CLOSE_TRADES_CBH&#xA;from (&#xA; select CID,PositionID,'C' OpenORClose,InstrumentID,IsBuy,AmountInUnitsDecimal ,CAST(CloseOccurred AS DATE) as Trade_date,ExecutionPrice,ExecutionTime&#xA;  ,OpenOccurred,CloseOccurred,HedgeServerID,OriginalPositionID,InitExecutionID,EndExecutionID,RequestOpenOccurred,RequestCloseOccurred,EndExecutionID ExecutionID&#xA;  ,RegulationID,IsSettled,USDConversionRate,isManual,InitForexRate,EndForexRate,OrderID,ActionType,StopRate,LimitRate,IsDiscounted&#xA; from #HISTORY_CLOSE     &#xA; )  PT&#xA;LEFT join #CLOSE_TRADES_HBC FLT ON FLT.PositionID=PT.PositionID&#xA;where FLT.PositionID is null &#xA;&#xA;CREATE NONCLUSTERED INDEX #ix_CLOSE_TRADES_CBH ON #CLOSE_TRADES_CBH (ExecutionID) &#xA;&#xA;/*---------------------------------------------------------------------*/    &#xA;DECLARE @MinRequestID2 INT    &#xA; DECLARE @MaxRequestID2 INT    &#xA; SELECT @MinRequestID2 = case when MAX(ExecutionID)-MIN(ExecutionID)&gt;100000000 then MAX(ExecutionID)- 5000000 else MIN(ExecutionID) end /* cancle old very executios that popup somtimes mostly crypto*/&#xA;      , @MaxRequestID2 = MAX(ExecutionID)     &#xA; FROM #CLOSE_TRADES_CBH WHERE ExecutionID &gt; 0    &#xA;     &#xA; DECLARE @BMinRequestID2 INT    &#xA; DECLARE @BMaxRequestID2 INT    &#xA; SELECT @BMinRequestID2 = case when MAX(ExecutionID)-MIN(ExecutionID)&gt;100000000 then MAX(ExecutionID)- 5000000 else MIN(ExecutionID) end /* cancle old very executios that popup somtimes mostly crypto*/ &#xA;      , @BMaxRequestID2 = MAX(ExecutionID)     &#xA; FROM #OPEN_TRADES_CBH  WHERE ExecutionID &gt; 0    &#xA;     &#xA; DECLARE @MinMinRequestID2 INT    &#xA; DECLARE @MaxMaxRequestID2 INT    &#xA;     &#xA; SELECT @MinMinRequestID2 = CASE WHEN @MinRequestID2 &lt; @BMinRequestID2 THEN @MinRequestID2 ELSE @BMinRequestID2 END    &#xA; SELECT @MaxMaxRequestID2 = CASE WHEN @MaxRequestID2 &gt; @BMaxRequestID2 THEN @MaxRequestID2 ELSE @BMaxRequestID2 END    &#xA;     &#xA;DROP TABLE IF EXISTS #rlel2    &#xA; SELECT RequestID, MarketTriggerRateTime,TriggerPriceRateID,BidSpreaded,AskSpreaded    &#xA; INTO #rlel2    &#xA; FROM eToroLogs_Real.eToroLogs_Real.Hedge.RequestLimitExecutionLog a with (nolock) &#xA; JOIN   [PriceLog].[History].[CurrencyPrice] b  ON a.TriggerPriceRateID=b.PriceRateID &#xA; WHERE RequestID &gt;= @MinMinRequestID2    &#xA; AND RequestID &lt;= @MaxMaxRequestID2 &#xA; AND b.Occurred&gt;=Cast(@RunDate as date)&#xA; and b.Occurred &lt;Cast(dateadd(dd,1,@RunDate) as date)&#xA;/*---------------------------------------------------------------------*/  &#xA;         &#xA;DROP TABLE IF EXISTS #rel2    &#xA;    &#xA; SELECT RequestID, RequestTime, HedgeExecutionModeID ,ClientViewRate   &#xA; INTO #rel2    &#xA; FROM eToroLogs_Real.eToroLogs_Real.Hedge.RequestExecutionLog WITH (NOLOCK)    &#xA; WHERE RequestID &gt;= @MinMinRequestID2 AND RequestID &lt;= @MaxMaxRequestID2          &#xA;/*---------------------------------------------------------------------*/  &#xA;DROP TABLE IF EXISTS #ALL_TRADES_CBH &#xA;select  *,'CBH' AS HedgingType &#xA;into #ALL_TRADES_CBH&#xA;FROM &#xA;(&#xA;SELECT  A.*&#xA;       ,rlel.MarketTriggerRateTime    &#xA;     ,rel.RequestTime&#xA;     ,CASE WHEN rlel.TriggerPriceRateID is not null THEN rlel.MarketTriggerRateTime  &#xA;       WHEN A.RequestCloseOccurred &lt; rel.RequestTime  THEN A.RequestCloseOccurred       &#xA;       ELSE rel.RequestTime END OrderTime&#xA;       ,rlel.TriggerPriceRateID&#xA;       ,rlel.BidSpreaded&#xA;       ,rlel.AskSpreaded &#xA;       ,rel.ClientViewRate&#xA;       ,rel.HedgeExecutionModeID&#xA; FROM #CLOSE_TRADES_CBH A     &#xA;LEFT JOIN #rel2 rel WITH (NOLOCK)    &#xA;  ON rel.RequestID = A.ExecutionID       &#xA; LEFT JOIN #rlel2 rlel with (nolock)    &#xA;  ON rlel.RequestID = A.ExecutionID   &#xA;UNION ALL&#xA;SELECT  B.*&#xA;       ,null MarketTriggerRateTime    &#xA;     ,rel.RequestTime&#xA;     ,CASE WHEN B.RequestOpenOccurred &lt; rel.RequestTime  THEN  B.RequestOpenOccurred ELSE rel.RequestTime  END  OrderTime &#xA;     ,null TriggerPriceRateID&#xA;     ,null BidSpreaded&#xA;     ,null AskSpreaded&#xA;     ,rel.ClientViewRate&#xA;     ,rel.HedgeExecutionModeID&#xA; FROM #OPEN_TRADES_CBH B     &#xA;LEFT JOIN #rel2 rel WITH (NOLOCK)    &#xA;  ON rel.RequestID = B.ExecutionID      &#xA;) UN_T2   &#xA;&#xA;CREATE Clustered INDEX #ix_ALL_TRADES_CBH ON #ALL_TRADES_CBH (PositionID) &#xA;/*---------------------------------------------------------------------*/ &#xA;DROP TABLE IF EXISTS #TRADES&#xA;select *,&#xA;CASE WHEN OpenORClose = 'C' THEN ( CASE ActionType    &#xA;         WHEN 1 THEN (CASE WHEN x.IsBuy=1 THEN x.BidSpreaded ELSE x.AskSpreaded END)   &#xA;         WHEN 5 THEN (CASE WHEN x.IsBuy=1 THEN x.BidSpreaded ELSE x.AskSpreaded END)   &#xA;         WHEN 0 THEN x.ClientViewRate  &#xA;         WHEN 14 THEN x.ClientViewRate  &#xA;                                    ELSE x.ClientViewRate END )  &#xA;   ELSE x.ClientViewRate END AS SpreadedOrderPrice,&#xA;CASE WHEN OpenORClose='O' then x.InitForexRate else x.EndForexRate end  SpreadedExecPrice,&#xA;CASE WHEN IsDiscounted=1 then (CASE WHEN OpenORClose='O' then x.InitForexRate else x.EndForexRate end) &#xA;       else ExecutionPrice_Calc &#xA;       end ExecutionPrice_fix,&#xA;   &#xA;CASE WHEN OpenORClose = 'O' then (case when OrderID is not null then 'OpenByOrder' else 'ManualOpen' end)  &#xA;       else (case when ActionType=0 then 'ManualClose' else Dat.ClosePositionActionName end) &#xA;       END ActionTypeName &#xA;  --- , CASE WHEN x.IsBuy=1 THEN x.BidSpreaded ELSE x.AskSpreaded END AS TriggerRate  &#xA;into #TRADES&#xA;from ( select *,case when ExecutionPrice is null  then ExecutionPrice_2 else ExecutionPrice end ExecutionPrice_Calc   from #ALL_TRADES_HBC &#xA;  UNION   ---- Dup  remove&#xA;  select *,case when ExecutionPrice is null  then ExecutionPrice_2 else ExecutionPrice  end ExecutionPrice_Calc from #ALL_TRADES_CBH   &#xA; ) x&#xA;left  join Dictionary.ClosePositionActionType Dat WITH (NOLOCK)  On x.ActionType = Dat.ID&#xA;&#xA;CREATE CLUSTERED INDEX #ix_Positions_ins ON #TRADES (InstrumentID) &#xA;/*---------------------------------------------------------------------*/ &#xA;drop table if exists #ALL_Withsplit&#xA;&#xA;SELECT EXP(SUM(LOG(AmountRatioUnAdjusted))) AmountRatioSplit, InstrumentID, PositionID ,Trade_date&#xA;into #ALL_Withsplit&#xA;FROM (&#xA;select case when OpenOccurred  &lt; MinDate AND CloseOccurred&gt; MinDate then 1 else 0 end as V &#xA;,b.*,a.PositionID,Trade_date&#xA;from #TRADES a &#xA;join #splits b on a.InstrumentID = b.InstrumentID &#xA;where OpenORClose = 'O'&#xA;and case when OpenOccurred  &lt; MinDate AND CloseOccurred &gt; MinDate then 1 else 0 end = 1&#xA;) a&#xA;group by PositionID, Trade_date,InstrumentID&#xA;&#xA;CREATE CLUSTERED INDEX #ci_split ON #ALL_Withsplit (PositionID)&#xA;&#xA;/*---------------------------------------------------------------------*/ &#xA;UPDATE a&#xA;SET AmountInUnitsDecimal =(CASE WHEN a.OpenORClose = 'O' THEN CAST(a.AmountInUnitsDecimal / ISNULL(b.AmountRatioSplit,1) AS DECIMAL(16,6)) ELSE a.AmountInUnitsDecimal END)&#xA;FROM #TRADES a&#xA;JOIN #ALL_Withsplit b&#xA;ON a.PositionID=b.PositionID &#xA;AND a.Trade_date=b.Trade_date &#xA;AND a.InstrumentID=b.InstrumentID&#xA;&#xA;/*---------------------------------------------------------------------*/ --- 20210531 added by  arielka&#xA;/* get migration time Prev &amp;curr RegulationID  */&#xA;drop table if exists #REG_MIGRATION ;&#xA; select CID,RegulationID as RegulationID,PrevValidTo as Migration_Occurred ,PrevRegulationID&#xA; into #REG_MIGRATION&#xA; from (&#xA; SELECT  CID, RegulationID ,ValidFrom,ValidTo,&#xA; LAG(ValidTo ,1 ) OVER (PARTITION BY CID ORDER BY ValidFrom) PrevValidTo, &#xA; LAG(RegulationID ,1 ) OVER (PARTITION BY CID ORDER BY ValidFrom) PrevRegulationID &#xA; FROM   [History].[BackOfficeCustomer] BOC  with (nolock) &#xA; ) REG_MIG&#xA; where cast(ValidFrom as date) =cast(PrevValidTo as date) and RegulationID&lt;&gt;PrevRegulationID&#xA; and  (RegulationID in (1,2,4,6,7,8,10) and PrevRegulationID in (1,2,4,6,7,8,10))&#xA; and cast(ValidFrom as date) =cast(@RunDate as date) &#xA;&#xA;Create Clustered index #CI_REG_MIGRATION on #REG_MIGRATION (CID)&#xA;Create NONClustered index #XI_REG_MIGRATION on #REG_MIGRATION (CID) include(Migration_Occurred) &#xA;&#xA;/* Update RegulatioID based on migration time */&#xA;update T&#xA;set RegulationID= case when T.ExecutionTime&lt;=RM.Migration_Occurred then RM.PrevRegulationID else RM.RegulationID end&#xA;from #TRADES T &#xA;join #REG_MIGRATION RM on T.CID=RM.CID&#xA;where  &#xA;T.RegulationID &lt;&gt;case when T.ExecutionTime&lt;=RM.Migration_Occurred then RM.PrevRegulationID else RM.RegulationID end&#xA;&#xA;/*---------------------------------------------------------------------*/&#xA;DROP TABLE IF EXISTS #Metadata&#xA; CREATE TABLE #Metadata (&#xA;  InstrumentID INT,&#xA;  InstrumentTypeID int,&#xA;  BuyCurrencyID INT,&#xA;  SellCurrencyID INT,&#xA;  BuyAbbreviation Varchar (20),&#xA;  SellAbbreviation Varchar (20),&#xA;  ISINCode Varchar (20),&#xA;  InstrumentDescription Varchar (200),&#xA;  SymbolFull Varchar (20),&#xA;  IsGBX int&#xA;  )&#xA;  &#xA;insert into #Metadata&#xA; select &#xA; TI.InstrumentID,&#xA; TGI.InstrumentTypeID,&#xA; TGI.BuyCurrencyID,&#xA; TGI.SellCurrencyID,&#xA; DC.Abbreviation BuyAbbreviation,&#xA; CASE WHEN TGI.SellCurrencyID = 666 THEN  REPLACE (DC1.Abbreviation, 'GBX', 'GBP')&#xA;        WHEN TGI.SellCurrencyID = 38  THEN  REPLACE (DC1.Abbreviation, 'CNH', 'CNY')&#xA;        ELSE DC1.Abbreviation &#xA;        END SellAbbreviation,&#xA;&#xA; CONVERT(VARCHAR(12),LTRIM(RTRIM(TI.ISINCode))) ISINCode, &#xA; REPLACE(TI.InstrumentDisplayName, ',', ' ') InstrumentDescription,&#xA; TI.SymbolFull,&#xA; CASE WHEN TGI.SellCurrencyID = 666 THEN 1 ELSE 0 end IsGBX&#xA;  from [Trade].[InstrumentMetaData] TI WITH(NOLOCK)&#xA;  JOIN [Trade].[GetInstrument] TGI WITH (NOLOCK)&#xA;   ON TGI.InstrumentID = TI.InstrumentID&#xA;  LEFT JOIN [Dictionary].[Currency] DC WITH (NOLOCK)&#xA;   ON DC.CurrencyID = TGI.BuyCurrencyID&#xA;  LEFT JOIN [Dictionary].[Currency] DC1 WITH (NOLOCK)&#xA;   ON DC1.CurrencyID = TGI.SellCurrencyID &#xA;   WHERE TGI.InstrumentTypeID IN (1,2,4,5,6,10)     &#xA;&#xA;/*---------------------------------------------------------------------*/&#xA;DROP TABLE IF EXISTS ##BEST_EX_RES_CLIENT&#xA;/*---------------------------------------------------------------------*/&#xA;Select T.CID,&#xA;T.PositionID,&#xA;M.InstrumentID,&#xA;M.InstrumentTypeID,&#xA;M.IsGBX,&#xA;T.ExecutionID,&#xA;T.HedgeServerID,&#xA;T.HedgingType,&#xA;T.OpenOccurred,&#xA;T.CloseOccurred,&#xA;T.RequestOpenOccurred,&#xA;T.RequestCloseOccurred,&#xA;T.MarketTriggerRateTime,&#xA;T.RequestTime,&#xA;0 TotalExecutionTime,&#xA;T.RegulationID,&#xA;T.ActionTypeName,&#xA;-----from here fields for  file &#xA;T.Trade_date,&#xA;cast(cast(T.PositionID as nvarchar(15))+OpenORClose as nvarchar(50)) as TradeID,&#xA;cast(T.CID as nvarchar(12)) AS  TraderID,&#xA;M.SymbolFull as Symbol,&#xA;M.ISINCode AS ISIN,&#xA;M.InstrumentDescription, &#xA;CASE WHEN OpenORClose='O' then (CASE WHEN T.IsBuy=1 THEN 'Buy' ELSE 'Sell' END )&#xA;  else (CASE WHEN T.IsBuy=1 THEN 'Sell' ELSE 'Buy' END )    END AS Side,&#xA;dic.Name AS [Asset class],&#xA;CAST(ISNULL(T.AmountInUnitsDecimal,0)  AS decimal(16,6))  as  Quantity,&#xA;CAST( (CASE WHEN M.IsGBX=1 THEN SpreadedOrderPrice/100.0 else SpreadedOrderPrice end ) AS decimal(16,6)) SpreadedOrderPrice,&#xA;CAST( (CASE WHEN M.IsGBX=1 THEN SpreadedExecPrice/100.0 else SpreadedExecPrice end)  AS decimal(16,6))  as SpreadedExecPrice, &#xA;CAST(CASE WHEN M.IsGBX=1 THEN isnull(T.ExecutionPrice_fix,0.0)/100.0 else T.ExecutionPrice_fix END AS decimal(16,6))  UnspreadedExecPrice,&#xA;cast(null as decimal(16,6)) HedgeOrderPrice,&#xA;cast(null as decimal(16,6)) HedgeExecutionPrice,&#xA;T.OrderTime,&#xA;&#xA;case when T.ExecutionTime &lt;T.OrderTime then T.OrderTime else  T.ExecutionTime end ExecutionTime ,   --- fix  20220112arielka&#xA;M.SellAbbreviation Currency,&#xA;CASE WHEN RegulationID=1 then 'Retail_eToroEU' &#xA;  WHEN RegulationID=2 then 'Retail_eToroUK'  &#xA;  WHEN RegulationID in (4,10) then 'Retail_eToroAU'&#xA;  WHEN RegulationID in (6,7,8) then 'Retail_eToroUS'&#xA;  else '' end LP_Type_Name,&#xA;cast(IsSettled as int) IsSettled,&#xA;-----from here fields added for Dashboard table&#xA;USDConversionRate,&#xA;case when REG.IsUSA =1 OR REG.Name ='NFA'  then 'eToro US'  else  REG.JurisdictionName end as eToroEntity,&#xA;case when IsSettled = 0 then 'CFD' else 'Real' end [CFD/Real],&#xA;isManual,&#xA;OpenORClose&#xA;into ##BEST_EX_RES_CLIENT&#xA;FROM #TRADES T&#xA;JOIN  #Metadata M ON T.InstrumentID = M.InstrumentID &#xA;JOIN [Dictionary].[CurrencyType] dic WITH (NOLOCK)  ON dic.CurrencyTypeID=M.InstrumentTypeID&#xA;join [Dictionary].[Regulation] REG  WITH (NOLOCK)  ON T.RegulationID=REG.ID&#xA;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
              <SQLTask:ParameterBinding
                SQLTask:ParameterName="0"
                SQLTask:DtsVariableName="User::RunDate"
                SQLTask:ParameterDirection="Input"
                SQLTask:DataType="7"
                SQLTask:ParameterSize="-1" />
            </SQLTask:SqlTaskData>
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
          DTS:refId="Package\Sequence Container 2\Execute Prep BestEX Hdge Data"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{C60AE674-DF34-4FC0-9DFD-E51DA71706B8}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Execute Prep BestEX Hdge Data"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2017 RC1; © 2017 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="4">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{FEAAEAC4-269C-4792-85B2-84BC820AB03E}"
              SQLTask:SqlStatementSource=" /*&#xA;-----------&#xA;BEST_EX_RES_HEDGE&#xA;-----------&#xA;*/&#xA;&#xA;declare  @RunDate datetime=CAST( ?  as datetime)&#xA;--declare  @RunDate date=CAST( '2021-07-06'  as datetime)&#xA;&#xA;declare @timediff int =0&#xA;declare @starttime datetime =getdate()&#xA;declare @TimePrint_IND int = 1  /* set to 1 for time prints*/&#xA;---------------------------------------------------------------------&#xA;---------------------------------------------------------------------&#xA;DECLARE @EndDate date = DATEADD(D,1,@RunDate)&#xA;&#xA; drop table if exists #Hedge_ExecutionLog -- for Hedge Trades&#xA; select  &#xA; cast(ExecutionLog.ExecutionTime as date) Trade_date,&#xA; ExecutionLog.HedgeServerID TradeID,&#xA; CASE WHEN ExecutionLog.IsBuy=1 THEN 'Buy' ELSE 'Sell' end Side,&#xA; ExecutionLog.Units Quantity,&#xA; null OrderPrice,&#xA; ExecutionLog.ExecutionRate ExecutionPrice,&#xA; Cast(ExecutionLog.SendTime as datetime) OrderTime,&#xA; Cast(ExecutionLog.ExecutionTime as datetime) ExecutionTime,&#xA; Cast(ExecutionLog.ReceivedTime as datetime) ReceivedTime,&#xA; ExecutionLog.LiquidityAccountID, &#xA; ExecutionLog.InstrumentID,&#xA; ExecutionLog.ProviderExecID,&#xA; Row_number() over (order by ExecutionLog.OrderID,ExecutionLog.SendTime,ExecutionLog.ProviderExecID)  rn_o,&#xA; case when HBCOrderLog.HedgeID is null then 'CBH' else 'HBC' end  HedgingType &#xA; INTO #Hedge_ExecutionLog&#xA; from [Hedge].[ExecutionLog] ExecutionLog WITH (NOLOCK) &#xA; left join  Hedge.HBCOrderLog  HBCOrderLog WITH (NOLOCK)  on ExecutionLog.OrderID=HBCOrderLog.HedgeID and HBCOrderLog.HedgeID&lt;&gt;-1 and HBCOrderLog.[StartTime]&gt;=@RunDate&#xA; where Success=1&#xA; and ExecutionLog.OrderState in (3,4)&#xA; and ExecutionLog.LogTime &gt;= Cast(@RunDate as date)&#xA; and ExecutionLog.LogTime&lt;Cast(dateadd(dd,1,@RunDate) as date)&#xA; and datediff(day,Cast(isnull(ExecutionLog.SendTime,ExecutionLog.ReceivedTime) as datetime) ,Cast(ExecutionLog.ExecutionTime as datetime) )&lt;30&#xA;---------------------------------------------------------------------&#xA;---------------------------------------------------------------------&#xA;DROP TABLE IF EXISTS #Metadata_H&#xA; CREATE TABLE #Metadata_H (&#xA;  InstrumentID INT,&#xA;  InstrumentTypeID int,&#xA;  BuyCurrencyID INT,&#xA;  SellCurrencyID INT,&#xA;  BuyAbbreviation Varchar (20),&#xA;  SellAbbreviation Varchar (20),&#xA;  ISINCode Varchar (20),&#xA;  InstrumentDescription Varchar (200),&#xA;  SymbolFull Varchar (20),&#xA;  IsGBX int&#xA;  )&#xA;  &#xA;insert into #Metadata_H&#xA; select &#xA; TI.InstrumentID,&#xA; TGI.InstrumentTypeID,&#xA; TGI.BuyCurrencyID,&#xA; TGI.SellCurrencyID,&#xA; DC.Abbreviation BuyAbbreviation,&#xA; CASE WHEN TGI.SellCurrencyID = 666 THEN  REPLACE (DC1.Abbreviation, 'GBX', 'GBP')&#xA;        WHEN TGI.SellCurrencyID = 38  THEN  REPLACE (DC1.Abbreviation, 'CNH', 'CNY')&#xA;        ELSE DC1.Abbreviation &#xA;        END SellAbbreviation,&#xA;&#xA; CONVERT(VARCHAR(12),LTRIM(RTRIM(TI.ISINCode))) ISINCode, &#xA; REPLACE(TI.InstrumentDisplayName, ',', ' ') InstrumentDescription,&#xA; TI.SymbolFull,&#xA; CASE WHEN TGI.SellCurrencyID = 666 THEN 1 ELSE 0 end IsGBX&#xA;  from [Trade].[InstrumentMetaData] TI WITH(NOLOCK)&#xA;  JOIN [Trade].[GetInstrument] TGI WITH (NOLOCK)&#xA;   ON TGI.InstrumentID = TI.InstrumentID&#xA;  LEFT JOIN [Dictionary].[Currency] DC WITH (NOLOCK)&#xA;   ON DC.CurrencyID = TGI.BuyCurrencyID&#xA;  LEFT JOIN [Dictionary].[Currency] DC1 WITH (NOLOCK)&#xA;   ON DC1.CurrencyID = TGI.SellCurrencyID &#xA;   WHERE TGI.InstrumentTypeID IN (1,2,4,5,6,10)  &#xA;   and TGI.InstrumentID  in (select distinct InstrumentID from #Hedge_ExecutionLog)&#xA; --------------------------------------------------------------------&#xA;---------------------------------------------------------------------&#xA;drop table  if exists #HS_TO_LP&#xA;&#xA;select  HS.HedgeServerID,HS.LiquidityAccountID,LA.LiquidityAccountName,LPT.Name &#xA;into #HS_TO_LP&#xA;from [Hedge].[HedgeServerToLiquidityAccount] HS WITH (NOLOCK) &#xA;left join [Trade].[LiquidityAccounts] LA WITH (NOLOCK)  ON HS.LiquidityAccountID=LA.LiquidityAccountID&#xA;left join [Trade].[LiquidityProviders] LP WITH (NOLOCK)  ON LA.LiquidityProviderID=LP.LiquidityProviderID&#xA;left join [Trade].[LiquidityProviderType] LPT WITH (NOLOCK)  on LP.[LiquidityProviderTypeID]=LPT.[LiquidityProviderTypeID] &#xA;&#xA;--$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$---------------------------------------------------------------------&#xA;&#xA;DROP TABLE IF EXISTS #PL_Order_Price&#xA;-- for HedgeRec&#xA; select [InstrumentID],Occurred,Bid,Ask&#xA;  into #PL_Order_Price&#xA; from(&#xA; select [InstrumentID],Occurred,Bid,Ask,row_number () over(partition by [InstrumentID],Occurred order by  abs(datediff(millisecond,Occurred,OccurredOnProvider)) asc) rn_by_OccurredOnProvider,datediff(millisecond,Occurred,OccurredOnProvider) dif&#xA; FROM [PriceLog].[History].[CurrencyPrice]&#xA; where Occurred&gt;= Cast(@RunDate as date)&#xA; and Occurred &lt;Cast(dateadd(dd,1,@RunDate) as date) &#xA;and InstrumentID in (select  distinct InstrumentID from #Hedge_ExecutionLog)&#xA;) filtering&#xA;where rn_by_OccurredOnProvider=1&#xA;-----&#xA;CREATE Clustered INDEX #ix_PL_Order_Price ON #PL_Order_Price (InstrumentID,Occurred) &#xA;&#xA;&#xA;---------------------------------------------------------------------&#xA;drop table if exists #PL_Price_Draft&#xA;select distinct HE.InstrumentID,B.Bid,B.Ask,cast(isnull(HE.OrderTime,HE.ReceivedTime) as datetime) OrderTime,B.Occurred&#xA;--,row_number() over (partition by HE.InstrumentID,cast(isnull(HE.OrderTime,HE.ReceivedTime) as datetime) order by HE.InstrumentID,cast(isnull(HE.OrderTime,HE.ReceivedTime) as datetime)) as RN&#xA;into #PL_Price_Draft&#xA;FROM #Hedge_ExecutionLog HE&#xA;JOIN  #Metadata_H M ON HE.InstrumentID = M.InstrumentID &#xA;left join #PL_Order_Price B&#xA;on  HE.[InstrumentID]=B.[InstrumentID] &#xA;&#xA;and isnull(HE.OrderTime,HE.ReceivedTime)=B.Occurred&#xA;&#xA;create  nonclustered  index #IX_PL_Price_Draft on #PL_Price_Draft ([InstrumentID],[Bid],[OrderTime])&#xA;&#xA;---------------------------------------------------------------------&#xA;alter table #PL_Price_Draft &#xA;add &#xA;BidRateByMin decimal (16,8),&#xA;AskRateByMin decimal (16,8),&#xA;OccurredByMin datetime,&#xA;BidRateByMax decimal (16,8),&#xA;AskRateByMax decimal (16,8),&#xA;OccurredByMax datetime&#xA;&#xA;&#xA;--------------------------------------------------------------&#xA;if @TimePrint_IND = 1&#xA;set   @timediff=datediff(minute,@starttime,getdate())&#xA;print  concat('first_lopp  start','@timediff-',@timediff)&#xA;set  @starttime =getdate()&#xA;set @timediff=0&#xA;---------------------------------------------------------------------&#xA;---------------------------------------------------------------------&#xA;-- loop fazes when no full match  &#xA;---------------------------------------------------------------------&#xA;declare @inst int&#xA;declare @exec_d datetime&#xA;&#xA;DECLARE Price_by_upper_min CURSOR FOR &#xA;  select distinct InstrumentID,OrderTime  &#xA;  from  #PL_Price_Draft where Bid is null  &#xA;  order by 1,2&#xA;&#xA;OPEN Price_by_upper_min&#xA;FETCH NEXT FROM Price_by_upper_min INTO @inst,@exec_d&#xA;WHILE @@FETCH_STATUS = 0 &#xA;BEGIN&#xA;update F &#xA;set BidRateByMin=new.Bid,&#xA;AskRateByMin=new.Ask,&#xA;OccurredByMin=new.Occurred&#xA;-- select  * &#xA;from  #PL_Price_Draft F&#xA;join &#xA;(&#xA;select b.InstrumentID,a.Bid,a.Ask,b.Occurred&#xA;from #PL_Order_Price a&#xA;join (select InstrumentID,min(Occurred) Occurred&#xA;  FROM #PL_Order_Price &#xA;  where Occurred&gt;= @exec_d&#xA;  and  InstrumentID=@inst&#xA;  group by InstrumentID&#xA;  ) b &#xA;  on a.InstrumentID=b.InstrumentID and a.Occurred=b.Occurred&#xA;) new&#xA;on new.InstrumentID=F.InstrumentID and F.OrderTime=@exec_d&#xA;where F.Bid is null &#xA;&#xA;  --print concat('#PL_Price_Draft',' - ',@@Rowcount,' - ',@inst,' - ',@exec_d) &#xA;FETCH NEXT FROM Price_by_upper_min INTO  @inst,@exec_d &#xA;END&#xA;CLOSE Price_by_upper_min &#xA;DEALLOCATE Price_by_upper_min &#xA;--GO&#xA;--------------------------------------------------------------&#xA;if @TimePrint_IND = 1&#xA;set   @timediff=datediff(minute,@starttime,getdate())&#xA;print  concat('scond_lopp  start','@timediff-',@timediff)&#xA;set  @starttime =getdate()&#xA;set @timediff=0&#xA;---------------------------------------------------------------------&#xA;declare @inst1 int&#xA;declare @exec_d1 datetime&#xA;&#xA;DECLARE Price_by_upper_max CURSOR FOR &#xA;  select distinct InstrumentID,OrderTime  &#xA;  from  #PL_Price_Draft where Bid is null &#xA;  order by 1,2&#xA;&#xA;OPEN Price_by_upper_max&#xA;FETCH NEXT FROM Price_by_upper_max INTO @inst1,@exec_d1&#xA;WHILE @@FETCH_STATUS = 0 &#xA;BEGIN&#xA;update F &#xA;set BidRateByMax=new.Bid,&#xA;AskRateByMax=new.Ask,&#xA;OccurredByMax=new.Occurred&#xA;from  #PL_Price_Draft F&#xA;join &#xA;(&#xA;select b.InstrumentID,a.Bid,a.Ask,b.Occurred&#xA;from #PL_Order_Price a&#xA;join (select InstrumentID,max(Occurred) Occurred&#xA;  FROM #PL_Order_Price &#xA;  where Occurred&lt;= @exec_d1&#xA;  and  InstrumentID=@inst1&#xA;  group by InstrumentID&#xA;  ) b &#xA;  on a.InstrumentID=b.InstrumentID and a.Occurred=b.Occurred&#xA;) new&#xA;on new.InstrumentID=F.InstrumentID and F.OrderTime=@exec_d1&#xA;where F.Bid is null &#xA;  --print concat('#PL_Price_Draft',' - ',@@Rowcount,' - ',@inst,' - ',@exec_d) &#xA;FETCH NEXT FROM Price_by_upper_max INTO  @inst1,@exec_d1 &#xA;END&#xA;CLOSE Price_by_upper_max &#xA;DEALLOCATE Price_by_upper_max &#xA;---GO&#xA;----------------------------------------------------------------&#xA;--------------------------------------------------------------&#xA;if @TimePrint_IND = 1&#xA;set   @timediff=datediff(minute,@starttime,getdate())&#xA;print  concat('end_lopp  start','@timediff-',@timediff)&#xA;set  @starttime =getdate()&#xA;set @timediff=0&#xA;---------------------------------------------------------------------&#xA;&#xA;&#xA;&#xA;----------------------------------------------------------------&#xA;DROP TABLE IF EXISTS #Hedge_Prices_Last&#xA;select  InstrumentID,OrderTime,OccurredByMin,OccurredByMax,&#xA;case when Bid is not null &#xA; then  Bid&#xA; when ABS(datediff(ms,OrderTime,OccurredByMin))&lt;=ABS(datediff(ms,OrderTime,OccurredByMax))&#xA; then BidRateByMin &#xA; when ABS(datediff(ms,OrderTime,OccurredByMin))&gt;ABS(datediff(ms,OrderTime,OccurredByMax))&#xA; then BidRateByMax&#xA; else  case when  OccurredByMax is NULL then BidRateByMin else BidRateByMax end&#xA; end as New_Bid,&#xA;case when Ask is not null &#xA; then  Ask&#xA; when ABS(datediff(ms,OrderTime,OccurredByMin))&lt;=ABS(datediff(ms,OrderTime,OccurredByMax))&#xA; then AskRateByMin &#xA; when ABS(datediff(ms,OrderTime,OccurredByMin))&gt;ABS(datediff(ms,OrderTime,OccurredByMax))&#xA; then AskRateByMax&#xA; else case when  OccurredByMax is NULL then AskRateByMin else AskRateByMax end &#xA; end as New_Ask &#xA;into  #Hedge_Prices_Last&#xA;from  #PL_Price_Draft &#xA;order by datediff(ms,OrderTime,OccurredByMin)  desc&#xA;&#xA;&#xA;----------------------------------------------------------------&#xA;&#xA;--$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$---------------------------------------------------------------------&#xA; DROP TABLE IF EXISTS ##BEST_EX_RES_HEDGE&#xA;---------------------------------------------------------------------&#xA;&#xA;SELECT   &#xA;null CID,&#xA;0 PositionID,&#xA;M.InstrumentID,&#xA;M.InstrumentTypeID,&#xA;0 IsGBX,&#xA;null ExecutionID,&#xA;HedgeServerID,&#xA;HE.HedgingType,&#xA;'9999-12-31' OpenOccurred,&#xA;'9999-12-31' CloseOccurred,&#xA;'9999-12-31' RequestOpenOccurred,&#xA;'9999-12-31' RequestCloseOccurred,&#xA;'9999-12-31' MarketTriggerRateTime,&#xA;'9999-12-31' RequestTime,&#xA;0 TotalExecutionTime,&#xA;null RegulationID,&#xA;'' ActionTypeName,&#xA;----- from here fields for file &#xA;HE.Trade_date,&#xA;convert(Nvarchar,HE.Trade_date,112)+'O'+cast(rn_o as nvarchar(10))  as TradeID,&#xA;cast('etoro' as nvarchar(12)) TraderID,&#xA;M.SymbolFull as Symbol,&#xA;M.ISINCode AS ISIN,&#xA;M.InstrumentDescription, &#xA;HE.Side,&#xA;dic.Name AS [Asset class],&#xA;HE.Quantity,&#xA;&#xA;null SpreadedOrderPrice,&#xA;null SpreadedExecPrice,&#xA;case when IsGBX=1 then HE.ExecutionPrice/100.00 else HE.ExecutionPrice end AS  UnspreadedExecPrice,&#xA;case when IsGBX=1 then  (case when HE.Side='Buy' then HP.New_Ask else HP.New_Bid end)/100.00 &#xA;     else (case when HE.Side='Buy' then HP.New_Ask else HP.New_Bid end)&#xA;     end AS  HedgeOrderPrice,&#xA;case when IsGBX=1 then HE.ExecutionPrice/100.00 else HE.ExecutionPrice end AS  HedgeExecutionPrice,&#xA;isnull(HE.OrderTime,HE.ReceivedTime) OrderTime,&#xA;HE.ExecutionTime,&#xA;&#xA;M.SellAbbreviation Currency,&#xA;HS.Name LP_Type_Name,&#xA;cast(null as  int)  IsSettled,&#xA;-----from here fields added for Dashboard table&#xA;null USDConversionRate,&#xA;cast(case when  InstrumentTypeID=5 AND PATINDEX('%REAL%',UPPER(LiquidityAccountName))&gt;0 and PATINDEX('%IB%',UPPER(LiquidityAccountName))&gt;0  &#xA;then 'eToro UK' else 'eToro EU' end as varchar(30)) eToroEntity,&#xA;cast(Case when  PATINDEX('%REAL%',UPPER(LiquidityAccountName))&gt;0 then 'Real' else 'CFD' END as varchar(4))   [CFD/Real],&#xA;1 isManual,&#xA;'' OpenORClose&#xA;into ##BEST_EX_RES_HEDGE&#xA;FROM #Hedge_ExecutionLog HE&#xA;JOIN  #Metadata_H M ON HE.InstrumentID = M.InstrumentID &#xA;Left JOIN [Dictionary].[CurrencyType] dic WITH (NOLOCK)  ON dic.CurrencyTypeID=M.InstrumentTypeID&#xA;LEFT JOIN #HS_TO_LP HS ON HE.LiquidityAccountID=HS.LiquidityAccountID&#xA;left join #Hedge_Prices_Last HP ON HE.InstrumentID=HP.InstrumentID and isnull(HE.OrderTime,HE.ReceivedTime)=HP.OrderTime &#xA;&#xA;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
              <SQLTask:ParameterBinding
                SQLTask:ParameterName="0"
                SQLTask:DtsVariableName="User::RunDate"
                SQLTask:ParameterDirection="Input"
                SQLTask:DataType="7"
                SQLTask:ParameterSize="-1" />
            </SQLTask:SqlTaskData>
          </DTS:ObjectData>
        </DTS:Executable>
      </DTS:Executables>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Sequence Prep BestEX Daily Table"
      DTS:CreationName="STOCK:SEQUENCE"
      DTS:Description="Sequence Container"
