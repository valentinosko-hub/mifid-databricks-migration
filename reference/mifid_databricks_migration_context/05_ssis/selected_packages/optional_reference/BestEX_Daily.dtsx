                DTS:Name="Arguments">@[$Project::Cappitech_SFTP_Log_arg] +" "+"/command " +"\"open "+  @[$Project::Cappitech_SFTP_Host] +" -hostkey="+"\"" +"\""+@[$Project::Cappitech_SFTP_hostkey]+"\"" +"\""+" -privatekey="+"\"" +"\""+  @[$Project::Cappitech_SFTP_privatekey_location]+"\"" +"\""+" "+ @[$Project::Cappitech_SFTP_raw_switch] +"\""+" \"CD "+ @[$Project::Cappitech_SFTP_Fol] + @[$Project::Cappitech_SFTP_SubDir_BestEx]+"\""+" \"put "+@[$Project::Cappitech_SFTP_put_switch]+" "+  @[User::RARFile]   +"\""+" \"exit\""</DTS:PropertyExpression>
