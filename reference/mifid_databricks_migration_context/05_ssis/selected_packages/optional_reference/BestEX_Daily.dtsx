        <DTS:Executable
          DTS:refId="Package\Prep client ext\DF Tranansactions"
          DTS:CreationName="Microsoft.Pipeline"
          DTS:DelayValidation="True"
          DTS:Description="Data Flow Task"
          DTS:DTSID="{414FCA5C-4BE2-4868-BE14-DECABEFF9686}"
          DTS:ExecutableType="Microsoft.Pipeline"
          DTS:LocaleID="-1"
          DTS:ObjectName="DF Tranansactions"
          DTS:TaskContact="Performs high-performance data extraction, transformation and loading;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1">
          <DTS:Variables />
          <DTS:ObjectData>
            <pipeline
              version="1">
              <components>
                <component
                  refId="Package\Prep client ext\DF Tranansactions\Get ALL Transactions"
                  componentClassID="Microsoft.OLEDBSource"
                  contactInfo="OLE DB Source;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;7"
                  description="OLE DB Source"
                  name="Get ALL Transactions"
                  usesDispositions="true"
                  validateExternalMetadata="False"
                  version="7">
                  <properties>
                    <property
                      dataType="System.Int32"
                      description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                      name="CommandTimeout">0</property>
                    <property
                      dataType="System.String"
                      description="Specifies the name of the database object used to open a rowset."
                      name="OpenRowset"></property>
                    <property
                      dataType="System.String"
                      description="Specifies the variable that contains the name of the database object used to open a rowset."
                      name="OpenRowsetVariable"></property>
                    <property
                      dataType="System.String"
                      description="The SQL command to be executed."
                      name="SqlCommand"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">declare  @RunDate date=CAST(? as datetime)

DECLARE @EndDate date = DATEADD(D,1,@RunDate)
;

/*----GET CUSTOMER POPULATION -----------------------------------------------------------------*/


WITH customer (CID,RegulationID,LabelID,PayerLevelID,CountryID)
AS  (
SELECT a.CID,b.RegulationID,a.LabelID,a.PlayerLevelID, a.CountryID
FROM (
SELECT  
CID, LabelID, PlayerStatusID,PlayerLevelID, CountryID, FirstName, LastName
FROM History.Customer  
WHERE ValidFrom &lt; DATEADD(D,1,@RunDate) AND ValidTo &gt; DATEADD(D,1,@RunDate)
AND LabelID not in (26,30)
AND not (PlayerLevelID=4 or CountryID=250)
) a
JOIN (
SELECT CID, RegulationID
FROM History.BackOfficeCustomer with (nolock)
WHERE ValidFrom &lt; DATEADD(D,1,@RunDate) AND ValidTo &gt; DATEADD(D,1,@RunDate)
---AND RegulationID in (1,2,4,6,7,8,10)    --- removed on 20220904
AND AccountTypeID NOT IN (7,9) --20220501 NirW DSR-2152
) b
ON a.CID = b.CID
JOIN Customer.Customer c  with (nolock)
ON a.CID = c.CID
)
insert into ##ALL_CustomerBX
SELECT a.[CID],a.[RegulationID]
FROM customer a

CREATE Clustered INDEX ##ix_ALL_CustomerBX ON ##ALL_CustomerBX (CID) ;



SELECT 
		cast(TROP.PositionID as bigint) PositionID
		, cast(null as bigint) OriginalPositionID
		 ,TROP.CID
		 ,TROP.InstrumentID
		 ,TROP.Occurred as OpenOccurred
		 ,cast(NULL as datetime)  as CloseOccurred
		 ,TROP.AmountInUnitsDecimal
		 ,TROP.InitForexRate
		 ,CAST(NULL AS DECIMAL(16,8)) AS EndForexRate
		 ,TROP.NetProfit
		 ,TROP.Amount
		 ,TROP.IsBuy
		 ,TROP.IsSettled
		 ,TROP.HedgeServerID
		 ,cast(TROP.InitExecutionID as bigint) InitExecutionID
		 ,cast(NULL as bigint) EndExecutionID	
		 ,TROP.RequestOccurred as RequestOpenOccurred
		 ,cast(NULL as datetime)  as RequestCloseOccurred
		 ,AC.RegulationID
		 ,Case when TROP.TreeID= TROP.PositionID Then 1 else 0 end as isManual
		 ,TROP.IsDiscounted	
		 
		 ,'O' OpenORClose
		 ,TROP.LotCountDecimal
		 ,TROP.OrderID
		 ,TROP.OrderType
		 ,cast(NULL as int) ExitOrderID
		 ,cast(NULL as int) ExitOrderType

		 ,TROP.InitForexPriceRateID
		 ,cast(NULL as bigint) EndForexPriceRateID	

		 ,cast(NULL as int) ActionType 
		 ,cast(null as decimal(16,8)) StopRate  
		 ,cast(null as decimal(16,8)) LimitRate
		 ,GETDATE() AS UpdateDate
		 ,'Trade.Position' SourceTable
                                       , null as PartialCloseRatio


	FROM Trade.PositionForExternalUse TROP WITH (NOLOCK) 
			JOIN ##ALL_CustomerBX AC  WITH (NOLOCK)  ON TROP.CID=AC.CID
		WHERE TROP.Occurred &gt;= Cast(@RunDate as date)
		And TROP.Occurred&lt;Cast(dateadd(dd,1,@RunDate) as date)

union all


SELECT  
		cast(HPOP.PositionID as bigint) PositionID
		,cast(HPOP.OriginalPositionID as bigint) OriginalPositionID
		 ,HPOP.CID
		 ,HPOP.InstrumentID
		 ,HPOP.OpenOccurred
		 ,cast(NULL as datetime) as CloseOccurred
		 ,HPOP.AmountInUnitsDecimal
		 ,HPOP.InitForexRate
		 ,HPOP.EndForexRate
		 ,HPOP.NetProfit
		 ,HPOP.Amount
		 ,HPOP.IsBuy
		 ,HPOP.IsSettled
 		 ,HPOP.HedgeServerID
		 ,cast(HPOP.InitExecutionID as bigint) InitExecutionID
		 ,cast(NULL as bigint) EndExecutionID
		 ,HPOP.RequestOpenOccurred
		 ,HPOP.RequestCloseOccurred
		 ,AC.RegulationID
		 ,Case when HPOP.TreeID= HPOP.PositionID Then 1 else 0 end as isManual
		 ,HPOP.IsDiscounted		
		 
		 ,'O' OpenORClose
		 ,HPOP.LotCountDecimal
		 ,HPOP.OrderID
		 ,HPOP.OrderType
		 ,cast(null as bigint) ExitOrderID
		 ,cast(null as int) ExitOrderType

		 ,HPOP.InitForexPriceRateID
		 ,cast(null as bigint) EndForexPriceRateID
		 
		 ,cast(null AS int) ActionType 
		 ,cast(null AS DECIMAL(16,8)) StopRate  
		 ,cast(null AS DECIMAL(16,8)) LimitRate
		 ,GETDATE() AS UpdateDate
		 ,'History.Position' SourceTable		 
                                      ,HPOP.PartialCloseRatio

	FROM History.PositionForExternalUse  HPOP WITH (NOLOCK) 
			JOIN ##ALL_CustomerBX AC  WITH (NOLOCK)  ON HPOP.CID=AC.CID
	WHERE (HPOP.OpenOccurred &gt;= Cast(@RunDate as date)
			And HPOP.OpenOccurred&lt;Cast(dateadd(dd,1,@RunDate) as date))

union all

SELECT 
		cast(HPCL.PositionID as bigint) PositionID
		,cast(HPCL.OriginalPositionID as bigint) OriginalPositionID
		 ,HPCL.CID
		 ,HPCL.InstrumentID
		 ,cast(NULL as datetime) as OpenOccurred
		 ,HPCL.CloseOccurred
		 ,AmountInUnitsDecimal
		 ,HPCL.InitForexRate
		 ,HPCL.EndForexRate
		 ,HPCL.Amount
		 ,HPCL.NetProfit
		 ,HPCL.IsBuy
		 ,HPCL.IsSettled
 		 ,HPCL.HedgeServerID
		,cast(Null as bigint) InitExecutionID
		 ,cast(HPCL.EndExecutionID as bigint) EndExecutionID
		 ,HPCL.RequestOpenOccurred
		 ,HPCL.RequestCloseOccurred
		 ,AC.RegulationID
		 ,Case when HPCL.ActionType in (0,17) then 1 else 0 end as isManual
		 ,HPCL.IsDiscounted	
		 
		 ,'C' OpenORClose
		 ,HPCL.LotCountDecimal
		 ,cast(null as bigint) OrderID
		 ,cast(null as int) OrderType
		 ,HPCL.ExitOrderID
		 ,HPCL.ExitOrderType

		 ,cast(null as bigint) InitForexPriceRateID
		 ,HPCL.EndForexPriceRateID

		 ,ActionType
		 ,StopRate  
		 ,LimitRate	
		 ,GETDATE() AS UpdateDate
		 ,'History.Position' SourceTable	
                                      ,null as PartialCloseRatio	 
	FROM History.PositionForExternalUse  HPCL WITH (NOLOCK) 
				JOIN ##ALL_CustomerBX AC  WITH (NOLOCK)  ON HPCL.CID=AC.CID
	WHERE (HPCL.CloseOccurred &gt;= Cast(@RunDate as date)
			And HPCL.CloseOccurred&lt;Cast(dateadd(dd,1,@RunDate) as date))</property>
