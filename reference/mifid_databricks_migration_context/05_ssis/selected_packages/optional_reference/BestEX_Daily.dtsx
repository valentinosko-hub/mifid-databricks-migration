      DTS:LocaleID="-1"
      DTS:ObjectName="Report Mail Sucsess"
      DTS:ThreadHint="2">
      <DTS:Variables />
      <DTS:PropertyExpression
        DTS:Name="MessageSource">"Stated At-"+ (DT_WSTR,25)  @[System::StartTime] +" || "+" Exection Duration In MIN "+"="+" "+(DT_WSTR,10) DATEDIFF( "Minute", @[System::StartTime] , GETDATE()  )</DTS:PropertyExpression>
      <DTS:PropertyExpression
        DTS:Name="Subject">"Package :  " +  @[System::PackageName] +" succeeded "+"  for Date=" + SUBSTRING(@[User::file_date],1,4)+"-"+SUBSTRING(@[User::file_date],5,2)+"-"+SUBSTRING(@[User::file_date],7,2)</DTS:PropertyExpression>
      <DTS:PropertyExpression
        DTS:Name="ToLine">@[User::EmailRecipients]</DTS:PropertyExpression>
      <DTS:EventHandlers>
