      <DTS:ObjectData>
        <SendMailTask:SendMailTaskData
          SendMailTask:SMTPServer="{31F1D4D2-6D24-430C-961C-AA559423F6E8}"
          SendMailTask:From="AZR-WE-BI-01@etoro.com"
