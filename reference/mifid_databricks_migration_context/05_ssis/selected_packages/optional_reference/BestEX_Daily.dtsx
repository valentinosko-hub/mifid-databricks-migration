        <DTS:Executable
          DTS:refId="Package\Prep client ext\Grt min max execution to Var"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{FC016EB9-9D53-41FE-9953-CCB940E26393}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Grt min max execution to Var"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{FD3E85FC-8647-4730-8683-6CC023DB7968}"
              SQLTask:SqlStatementSource="/**&#xA;max-1 000 000 000 -  to take care unusual min(Init Execution ID ) that can happen time to time&#xA;**/&#xA;select max(ExecutionID)-100000000 min_exe ,max(ExecutionID) max_exe&#xA;from &#xA;(&#xA;select  min(InitExecutionID ) ExecutionID from Reg_Ext_BX_Transactions  where InitExecutionID&gt;0&#xA;union all&#xA;select  min(EndExecutionID ) ExecutionID from Reg_Ext_BX_Transactions  where EndExecutionID&gt;0&#xA;union all&#xA;select  max(EndExecutionID) ExecutionID from Reg_Ext_BX_Transactions&#xA;union all&#xA;select  max(InitExecutionID) ExecutionID from Reg_Ext_BX_Transactions&#xA;) a"
              SQLTask:ResultType="ResultSetType_SingleRow" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
              <SQLTask:ResultBinding
                SQLTask:ResultName="0"
                SQLTask:DtsVariableName="User::MinExecutionID" />
              <SQLTask:ResultBinding
                SQLTask:ResultName="1"
                SQLTask:DtsVariableName="User::MaxExecutionID" />
            </SQLTask:SqlTaskData>
          </DTS:ObjectData>
        </DTS:Executable>
