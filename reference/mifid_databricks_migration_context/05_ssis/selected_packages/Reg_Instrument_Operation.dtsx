                    <property
                      dataType="System.String"
                      description="The SQL command to be executed."
                      name="SqlCommand"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">select 
TI.InstrumentID,
TI.InstrumentTypeID,
TI.InstrumentDisplayName,
TI.Symbol,
TI.SymbolFull,
TI.Tradable,
TI.ISINCode,
TI.InstrumentVisible,
TGI.BuyCurrencyID,
TGI.SellCurrencyID,
TI.ContractExpire,
TI.ExchangeID,
GetDate() UpdateDate 
 from [Trade].[InstrumentMetaData] TI WITH(NOLOCK)
JOIN [Trade].[GetInstrument] TGI WITH (NOLOCK)
ON TGI.InstrumentID = TI.InstrumentID</property>
