                    <component
                      refId="Package\Sequence Container\Reg Out MIFID Pop\MIFID2_ext_RegChange_Customer MIFID2_RegChange_ext_Position\TradePosition 1"
                      componentClassID="Microsoft.OLEDBSource"
                      contactInfo="OLE DB Source;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;7"
                      description="OLE DB Source"
                      name="TradePosition 1"
                      usesDispositions="true"
                      validateExternalMetadata="False"
                      version="7">
                      <properties>
                        <property
                          dataType="System.Int32"
                          description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                          name="CommandTimeout">0</property>
                        <property
                          dataType="System.String"
                          description="Specifies the name of the database object used to open a rowset."
                          name="OpenRowset"></property>
                        <property
                          dataType="System.String"
                          description="Specifies the variable that contains the name of the database object used to open a rowset."
                          name="OpenRowsetVariable"></property>
                        <property
                          dataType="System.String"
                          description="The SQL command to be executed."
                          name="SqlCommand"
                          UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">declare @StartDate date = ?
--declare @StartDate date = '2022-03-14'
DECLARE @EndDate date = DATEADD(D,1,@StartDate)


SELECT
	cast(tp.PositionID as bigint) PositionID,
	cast(tp.ParentPositionID as bigint) ParentPositionID ,
	tp.CID,
	tp.Occurred AS OpenOccurred,
	cast(NULL as datetime) AS CloseOccurred,
	tp.InitForexRate,
	cast(NULL as Decimal(16,8)) AS EndForexRate, 
	tp.AmountInUnitsDecimal,
	tp.InstrumentID,
	tp.IsBuy,
	Leverage,
	cast(NULL as Decimal(16,8))  AS LastOpConversionRate,
	tp.MirrorID,
	cast(InitExecutionID as bigint) as InitExecutionID,
	cast(NULL as bigint) AS EndExecutionID,
	HedgeServerID,
	IsSettled,
	InitForexPriceRateID,
	cast(NULL as bigint) AS EndForexPriceRateID,
	LastOpPriceRate,
	cast(NULL as bigint) AS OriginalPositionID,
	InitialUnits
FROM  Trade.PositionForExternalUse tp WITH (NOLOCK)
	--JOIN Trade.GetInstrument TGI ON tp.InstrumentID = TGI.InstrumentID
	--JOIN Dictionary.Currency DC  
	--	ON DC.CurrencyID = TGI.BuyCurrencyID 
WHERE tp.Occurred &gt;= @StartDate
	AND tp.Occurred &lt; @EndDate
--AND (TGI.InstrumentTypeID not in (1,5,10) OR (TGI.InstrumentTypeID = 5 AND DC.EEAStockExchange =1)) --20190922 InstrumentFilter made in proc
--AND tp.InstrumentID &lt; 100000
ORDER BY tp.CID</property>
