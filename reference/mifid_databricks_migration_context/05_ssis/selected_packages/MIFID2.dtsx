--declare @StartDate date = '2022-03-14'
DECLARE @EndDate date = DATEADD(D,1,@StartDate)


select CID,RegulationID,AccountTypeID
, Lei
FROM (
		SELECT CID,RegulationID,AccountTypeID,Lei
		,ROW_NUMBER() OVER (PARTITION BY CID ORDER BY ValidTo DESC) AS rn
		from History.BackOfficeCustomer WITH (NOLOCK)
		WHERE 
	  ValidFrom &lt;@EndDate and ValidTo &gt;= @EndDate
) a
where rn=1 	And RegulationID in (1,2,9,11) -- Cysec/FCA -- DSR-5008 added 9 Seychelles 
AND AccountTypeID NOT IN (7,9) -- exclude CopyFund
ORDER BY CID</property>
