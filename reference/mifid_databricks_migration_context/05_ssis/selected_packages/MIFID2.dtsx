DECLARE @EndDate datetime = DATEADD(D,1,@StartDate)


SELECT cast(PositionID as bigint)PositionID ,[LastOpPriceRate] AS ChangeLogLastOpPriceRate,[Occurred] AS ChangeLogOccurred, [ChangeTypeID],
IsSettled
FROM History.PositionChangeLog  with (nolock)
WHERE Occurred &gt;= @StartDate  and Occurred &lt; @EndDate  AND ChangeTypeID = 0</property>
