                        <property
                          dataType="System.String"
                          description="The SQL command to be executed."
                          name="SqlCommand"
                          UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">/*** HistoryBackOfficeCustomer for Not-MIFID ***/

declare @StartDate date = ?
declare @EndDate date = DATEADD(D,1,@StartDate)


select CID,RegulationID,AccountTypeID,Lei
FROM (
		SELECT boc.CID,RegulationID,AccountTypeID,Lei
		,ROW_NUMBER() OVER (PARTITION BY boc.CID ORDER BY ValidTo DESC) AS rn
                                      From History.BackOfficeCustomer boc WITH (NOLOCK)
		WHERE 
	  ValidFrom &lt;@EndDate and ValidTo &gt;= @EndDate
) a
where rn=1 	And RegulationID NOT in (1,2,9,11) -- Not MIFID. Check later if had activity under MIFID and changed reguldation /*DSR-5008 added Seychelles*/
AND AccountTypeID NOT IN (7,9) -- exclude CopyFund
ORDER BY CID</property>
