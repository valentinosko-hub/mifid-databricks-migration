                      dataType="System.String"
                      description="The SQL command to be executed."
                      name="SqlCommand"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT DISTINCT a.CID 
FROM MIFID2_NPD_TRAX a
JOIN (SELECT CID, MAX(ReportDate) AS ReportDate 
		FROM MIFID2_NPD_TRAX 
		GROUP BY CID
		) b ON a.CID=b.CID and a.ReportDate=b.ReportDate
WHERE (a.AcceptedTRAX=0 or a.AcceptedTRAX is null)
ORDER BY a.CID</property>
