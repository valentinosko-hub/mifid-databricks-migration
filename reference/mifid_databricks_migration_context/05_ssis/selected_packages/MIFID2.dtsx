            <SQLTask:SqlTaskData
              SQLTask:Connection="{84BE269E-DF52-4F0E-8645-39996558119C}"
              SQLTask:SqlStatementSource="&#xA;declare @DateInt int = cast(convert(varchar(20),?,112) as int)&#xA;declare @flag int=0 &#xA;Declare @flag_ssis int =0&#xA;while @flag&lt;2 or @flag_ssis&lt;1&#xA;begin &#xA;    &#xA;set @flag=0&#xA;&#xA;----Flag 1--------------------------------------&#xA;&#xA;    set @flag=(&#xA; select count(1) from (&#xA;    select ReportName,max(StartTime) StartTime&#xA;    from RegReportsLog&#xA;    where  PackageName='ASIC_Positions_agg_trn_sym'&#xA;    and TableName in ('ASIC_Transactions','SP_ASIC_PositionReport_Agg')&#xA;    and Status ='Completed'&#xA;    and  DateID=@DateInt&#xA;    group by ReportName&#xA;    ) a&#xA;    ) ; &#xA; set @flag_ssis = (&#xA;      select count(1)&#xA;      FROM &#xA;      (select PackageName,max(StartTime) MX_StartTime&#xA;      from dbo.Reg_SSIS_Log&#xA;      where PackageName in ('ASIC_Positions_agg_trn_sym')&#xA;      and  StartTime&gt;=CAST(getutcdate() as date)&#xA;      and  Status='Completed'&#xA;      Group by PackageName&#xA;      )  aaa&#xA;      )&#xA;&#xA;    print @flag&#xA; print @flag_ssis&#xA;&#xA; if @flag = 2 or @flag_ssis=1&#xA;  BREAK&#xA; Else&#xA;&#xA; WAITFOR DELAY '00:05:00'    &#xA;&#xA;end" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
              <SQLTask:ParameterBinding
                SQLTask:ParameterName="0"
                SQLTask:DtsVariableName="User::StartDate"
                SQLTask:ParameterDirection="Input"
                SQLTask:DataType="7"
                SQLTask:ParameterSize="-1" />
            </SQLTask:SqlTaskData>
