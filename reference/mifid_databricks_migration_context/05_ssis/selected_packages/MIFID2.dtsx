                <component
                  refId="Package\Sequence Container\MIFID2_ext_Customer MIFID2_ext_Position\HistoryCustomer"
                  componentClassID="Microsoft.OLEDBSource"
                  contactInfo="OLE DB Source;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;7"
                  description="OLE DB Source"
                  name="HistoryCustomer"
                  usesDispositions="true"
                  validateExternalMetadata="False"
                  version="7">
                  <properties>
                    <property
                      dataType="System.Int32"
                      description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                      name="CommandTimeout">0</property>
                    <property
                      dataType="System.String"
                      description="Specifies the name of the database object used to open a rowset."
                      name="OpenRowset"></property>
                    <property
                      dataType="System.String"
                      description="Specifies the variable that contains the name of the database object used to open a rowset."
                      name="OpenRowsetVariable"></property>
                    <property
                      dataType="System.String"
                      description="The SQL command to be executed."
                      name="SqlCommand"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">declare @StartDate date = ?
--declare @StartDate date = '2022-03-14'
DECLARE @EndDate date = DATEADD(D,1,@StartDate)

SELECT  a.CID, a.GCID, a.PlayerLevelID, a.PlayerStatusID, a.CountryID, a.LabelID 
,c.FirstName, c.LastName, c.BirthDate
,c.CountryIDByIP, c.FirstName AS curFirstName, c.LastName AS curLastName, c.BirthDate AS curBirthDate, c.CitizenshipCountryID
FROM (
		SELECT a.CID,GCID,PlayerLevelID,PlayerStatusID,FirstName, LastName,BirthDate, CountryID,LabelID
		,ROW_NUMBER() OVER (PARTITION BY a.CID ORDER BY a.ValidTo DESC) AS rn
		FROM History.Customer a WITH (NOLOCK)
		WHERE  a.ValidFrom &lt;@EndDate and a.ValidTo &gt;= @EndDate 
		) a
	JOIN Customer.Customer c  WITH (NOLOCK)
		ON a.CID = c.CID
WHERE rn =1 
AND a.LabelID NOT IN (26,30) 
ORDER BY CID</property>
