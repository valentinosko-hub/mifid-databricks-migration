    <DTS:Executable
      DTS:refId="Package\Pull Controls"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{D46F878F-12EA-427D-AD21-07149DF3E838}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Pull Controls"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2017 RC1; © 2017 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{2E24E30F-93B3-4DE0-AACE-0CD289C11772}"
          SQLTask:SqlStatementSource="SELECT&#xA;  ReportFolderName,&#xA; CASE WHEN IsManual = 0 THEN DATEADD(DD,-1,CONVERT(DATETIME,CONVERT(VARCHAR,DATEADD(DD,0,GETDATE()),112) + ' 0:00'))&#xA;   ELSE StartDate_Manual END AS StartDate,&#xA;CASE  WHEN IsManual = 0 THEN CONVERT(DATETIME,CONVERT(VARCHAR,DATEADD(DD,0,GETDATE()),112) + ' 0:00')&#xA;     ELSE EndDate_Manual END AS EndDate,&#xA; FileName,&#xA; FileNameExtention,&#xA; EmailRecipients,&#xA; IsFTP,&#xA;Active&#xA;FROM Reports_Control&#xA;WHERE ReportType = ?"
          SQLTask:ResultType="ResultSetType_SingleRow" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
          <SQLTask:ResultBinding
            SQLTask:ResultName="0"
            SQLTask:DtsVariableName="User::ReportFolderName" />
          <SQLTask:ResultBinding
            SQLTask:ResultName="1"
            SQLTask:DtsVariableName="User::StartDate" />
          <SQLTask:ResultBinding
            SQLTask:ResultName="2"
            SQLTask:DtsVariableName="User::EndDate" />
          <SQLTask:ResultBinding
            SQLTask:ResultName="3"
            SQLTask:DtsVariableName="User::FileName" />
          <SQLTask:ResultBinding
            SQLTask:ResultName="4"
            SQLTask:DtsVariableName="User::FileNameExtention" />
          <SQLTask:ResultBinding
            SQLTask:ResultName="5"
            SQLTask:DtsVariableName="User::EmailRecipients" />
          <SQLTask:ResultBinding
            SQLTask:ResultName="6"
            SQLTask:DtsVariableName="User::IsFTP" />
          <SQLTask:ResultBinding
            SQLTask:ResultName="7"
            SQLTask:DtsVariableName="User::Active" />
          <SQLTask:ParameterBinding
            SQLTask:ParameterName="0"
            SQLTask:DtsVariableName="$Package::ReportType"
            SQLTask:ParameterDirection="Input"
            SQLTask:DataType="3"
            SQLTask:ParameterSize="-1" />
        </SQLTask:SqlTaskData>
      </DTS:ObjectData>
    </DTS:Executable>
