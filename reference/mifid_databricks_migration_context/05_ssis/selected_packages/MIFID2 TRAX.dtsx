                      DTS:ThreadHint="0">
                      <DTS:Variables />
                      <DTS:PropertyExpression
                        DTS:Name="Arguments">@[User::TraxLog]+ " "+"/command "+"\"open sftp://"+ @[User::TRAX_Account] +":"+ @[User::TRAX_Pass]+"@"+ @[$Project::TRAX_ConnectionString] +"\""+" \"cd "+ @[$Project::TRAX_Directory]+"\""+" \"put "+ @[User::TRAX_OutgoingName] +"\""+" \"exit\""</DTS:PropertyExpression>
                      <DTS:ObjectData>
                        <ExecuteProcessData
                          Executable="C:\Program Files (x86)\WinSCP\winscp.com"
                          Arguments="/log=&quot;\\regulations.file.core.windows.net\regulations\TraxLog\trax.log&quot; /command &quot;open sftp://:KjF7AMSKZ4kTttan@edsftp.traxinsight.com:22&quot; &quot;cd /inbound&quot; &quot;put C:\TRAX_SFTPUpload\TRAX_NPD_NPDM__20220314_.csv&quot; &quot;exit&quot;"
