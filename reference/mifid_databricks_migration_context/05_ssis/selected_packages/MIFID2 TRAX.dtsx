      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{2E24E30F-93B3-4DE0-AACE-0CD289C11772}"
          SQLTask:SqlStatementSource="  &#xA;  declare @IsJOBInProgress int = 1&#xA;while  @IsJOBInProgress&gt;0 &#xA;Begin &#xA;waitfor delay '00:00:30'&#xA;&#xA;set @IsJOBInProgress =(select  count(*) from (&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;select PackageName,StartTime,max(StartTime) over( ) MX_StartTime , EndTime&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;from [dbo].[RegReportsLog]&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;where TableName in ('MIFID2_Extract')&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;and  StartTime&gt;=CAST(getutcdate() as date)&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;)a&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;where StartTime=MX_StartTime&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;and EndTime is NULL&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;)&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#xA;&#xA;END" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
